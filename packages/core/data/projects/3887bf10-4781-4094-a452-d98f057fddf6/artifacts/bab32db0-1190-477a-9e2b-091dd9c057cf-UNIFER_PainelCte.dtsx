        <SQLTask:SqlTaskData
          SQLTask:Connection="{B1280D06-58A9-4DFC-B6B3-B5A9AA7AE84C}"
          SQLTask:SqlStatementSource="BEGIN TRANSACTION &#xA;IF ? = 1&#xA;BEGIN&#xA;&#xA;    INSERT INTO replicador.UNIFER_PAINEL_CTE (&#xA;&#x9;&#x9; [__operation]&#xA;&#x9;&#x9;,PCT_IDT_PCT&#xA;&#x9;&#x9;,PCT_IDT_PCT_ORG&#xA;&#x9;&#x9;,PCG_IDT_PCG&#xA;&#x9;&#x9;,FX_ID_FLX&#xA;&#x9;&#x9;,PCT_DAT_IUN&#xA;&#x9;&#x9;,PCT_DAT_FUN&#xA;&#x9;&#x9;,PCT_DAT_IUM&#xA;&#x9;&#x9;,PCT_DAT_FUM&#xA;&#x9;&#x9;,PCT_DAT_ITC&#xA;&#x9;&#x9;,PCT_DAT_FTC&#xA;&#x9;&#x9;,PCT_DAT_ISC&#xA;&#x9;&#x9;,PCT_DAT_FSC&#xA;&#x9;&#x9;,PCT_IND_ATU&#xA;&#x9;&#x9;,PCT_DAT_RTN&#xA;&#x9;&#x9;,PCT_DAT_AUT&#xA;&#x9;&#x9;,PCT_DAT_ORC&#xA;&#x9;&#x9;,PCT_IND_TIP&#xA;&#x9;&#x9;,PCT_IND_SFZ&#xA;&#x9;&#x9;,PCT_TXT_SIT&#xA;&#x9;&#x9;,PCT_TXT_MSR&#xA;&#x9;&#x9;,PCT_IND_ERR&#xA;&#x9;&#x9;,PCT_DSC_XML&#xA;&#x9;&#x9;,PCT_TXT_MSD&#xA;&#x9;&#x9;,PCT_DSC_CHV&#xA;&#x9;&#x9;,PCT_NUM_SCT&#xA;&#x9;&#x9;,PCT_NUM_CTE&#xA;&#x9;&#x9;,PCT_COD_MTR&#xA;&#x9;&#x9;,PCT_DET_MRC&#xA;&#x9;&#x9;,PCT_TIMESTAMP&#xA;&#x9;&#x9;,PCT_IND_ORT&#xA;&#x9;&#x9;,PCT_IND_CNT&#xA;&#x9;&#x9;,PCT_IND_ORC&#xA;&#x9;&#x9;,PCT_IND_CTM&#xA;&#x9;&#x9;,PCT_DAT_ISZ&#xA;&#x9;&#x9;,PCT_DAT_BSC&#xA;&#x9;&#x9;,PCT_IND_RJC&#xA;&#x9;&#x9;,PCT_IND_DEX&#xA;&#x9;&#x9;,PCT_IND_CRT&#xA;&#x9;&#x9;,PCT_DAT_CNT&#xA;&#x9;&#x9;,PCT_CHV_SCB&#xA;&#x9;&#x9;,PCT_NUM_TCFL&#xA;&#x9;&#x9;,PCT_IND_TCG&#xA;&#x9;&#x9;,PCT_IND_ASC&#xA;&#x9;&#x9;,DT_ALTERACAO&#xA;&#x9;)&#xA;&#x9;SELECT&#xA;&#x9;&#x9; 1 AS [__operation]&#xA;&#x9;&#x9;,PCT_IDT_PCT&#xA;&#x9;&#x9;,PCT_IDT_PCT_ORG&#xA;&#x9;&#x9;,PCG_IDT_PCG&#xA;&#x9;&#x9;,FX_ID_FLX&#xA;&#x9;&#x9;,PCT_DAT_IUN&#xA;&#x9;&#x9;,PCT_DAT_FUN&#xA;&#x9;&#x9;,PCT_DAT_IUM&#xA;&#x9;&#x9;,PCT_DAT_FUM&#xA;&#x9;&#x9;,PCT_DAT_ITC&#xA;&#x9;&#x9;,PCT_DAT_FTC&#xA;&#x9;&#x9;,PCT_DAT_ISC&#xA;&#x9;&#x9;,PCT_DAT_FSC&#xA;&#x9;&#x9;,PCT_IND_ATU&#xA;&#x9;&#x9;,PCT_DAT_RTN&#xA;&#x9;&#x9;,PCT_DAT_AUT&#xA;&#x9;&#x9;,PCT_DAT_ORC&#xA;&#x9;&#x9;,PCT_IND_TIP&#xA;&#x9;&#x9;,PCT_IND_SFZ&#xA;&#x9;&#x9;,PCT_TXT_SIT&#xA;&#x9;&#x9;,PCT_TXT_MSR&#xA;&#x9;&#x9;,PCT_IND_ERR&#xA;&#x9;&#x9;,PCT_DSC_XML&#xA;&#x9;&#x9;,PCT_TXT_MSD&#xA;&#x9;&#x9;,PCT_DSC_CHV&#xA;&#x9;&#x9;,PCT_NUM_SCT&#xA;&#x9;&#x9;,PCT_NUM_CTE&#xA;&#x9;&#x9;,PCT_COD_MTR&#xA;&#x9;&#x9;,PCT_DET_MRC&#xA;&#x9;&#x9;,PCT_TIMESTAMP&#xA;&#x9;&#x9;,PCT_IND_ORT&#xA;&#x9;&#x9;,PCT_IND_CNT&#xA;&#x9;&#x9;,PCT_IND_ORC&#xA;&#x9;&#x9;,PCT_IND_CTM&#xA;&#x9;&#x9;,PCT_DAT_ISZ&#xA;&#x9;&#x9;,PCT_DAT_BSC&#xA;&#x9;&#x9;,PCT_IND_RJC&#xA;&#x9;&#x9;,PCT_IND_DEX&#xA;&#x9;&#x9;,PCT_IND_CRT&#xA;&#x9;&#x9;,PCT_DAT_CNT&#xA;&#x9;&#x9;,PCT_CHV_SCB&#xA;&#x9;&#x9;,PCT_NUM_TCFL&#xA;&#x9;&#x9;,PCT_IND_TCG&#xA;&#x9;&#x9;,PCT_IND_ASC&#xA;&#x9;&#x9;,DT_ALTERACAO&#xA;&#x9;FROM UNIFER.PAINEL_CTE;&#xA;&#x9;&#xA;    TRUNCATE TABLE UNIFER.PAINEL_CTE;&#xA;&#x9;&#xA;END&#xA;&#xA;IF ? = 1&#xA;BEGIN&#xA;&#xA;&#x9;INSERT INTO replicador.UNIFER_PAINEL_CTE (&#xA;&#x9;&#x9; [__operation]&#xA;&#x9;&#x9;,PCT_IDT_PCT&#xA;&#x9;&#x9;,PCT_IDT_PCT_ORG&#xA;&#x9;&#x9;,PCG_IDT_PCG&#xA;&#x9;&#x9;,FX_ID_FLX&#xA;&#x9;&#x9;,PCT_DAT_IUN&#xA;&#x9;&#x9;,PCT_DAT_FUN&#xA;&#x9;&#x9;,PCT_DAT_IUM&#xA;&#x9;&#x9;,PCT_DAT_FUM&#xA;&#x9;&#x9;,PCT_DAT_ITC&#xA;&#x9;&#x9;,PCT_DAT_FTC&#xA;&#x9;&#x9;,PCT_DAT_ISC&#xA;&#x9;&#x9;,PCT_DAT_FSC&#xA;&#x9;&#x9;,PCT_IND_ATU&#xA;&#x9;&#x9;,PCT_DAT_RTN&#xA;&#x9;&#x9;,PCT_DAT_AUT&#xA;&#x9;&#x9;,PCT_DAT_ORC&#xA;&#x9;&#x9;,PCT_IND_TIP&#xA;&#x9;&#x9;,PCT_IND_SFZ&#xA;&#x9;&#x9;,PCT_TXT_SIT&#xA;&#x9;&#x9;,PCT_TXT_MSR&#xA;&#x9;&#x9;,PCT_IND_ERR&#xA;&#x9;&#x9;,PCT_DSC_XML&#xA;&#x9;&#x9;,PCT_TXT_MSD&#xA;&#x9;&#x9;,PCT_DSC_CHV&#xA;&#x9;&#x9;,PCT_NUM_SCT&#xA;&#x9;&#x9;,PCT_NUM_CTE&#xA;&#x9;&#x9;,PCT_COD_MTR&#xA;&#x9;&#x9;,PCT_DET_MRC&#xA;&#x9;&#x9;,PCT_TIMESTAMP&#xA;&#x9;&#x9;,PCT_IND_ORT&#xA;&#x9;&#x9;,PCT_IND_CNT&#xA;&#x9;&#x9;,PCT_IND_ORC&#xA;&#x9;&#x9;,PCT_IND_CTM&#xA;&#x9;&#x9;,PCT_DAT_ISZ&#xA;&#x9;&#x9;,PCT_DAT_BSC&#xA;&#x9;&#x9;,PCT_IND_RJC&#xA;&#x9;&#x9;,PCT_IND_DEX&#xA;&#x9;&#x9;,PCT_IND_CRT&#xA;&#x9;&#x9;,PCT_DAT_CNT&#xA;&#x9;&#x9;,PCT_CHV_SCB&#xA;&#x9;&#x9;,PCT_NUM_TCFL&#xA;&#x9;&#x9;,PCT_IND_TCG&#xA;&#x9;&#x9;,PCT_IND_ASC&#xA;&#x9;&#x9;,DT_ALTERACAO&#xA;&#x9;)&#xA;&#x9;SELECT&#xA;&#x9;&#x9; 1 AS [__operation]&#xA;&#x9;&#x9;,PCT_IDT_PCT&#xA;&#x9;&#x9;,PCT_IDT_PCT_ORG&#xA;&#x9;&#x9;,PCG_IDT_PCG&#xA;&#x9;&#x9;,FX_ID_FLX&#xA;&#x9;&#x9;,PCT_DAT_IUN&#xA;&#x9;&#x9;,PCT_DAT_FUN&#xA;&#x9;&#x9;,PCT_DAT_IUM&#xA;&#x9;&#x9;,PCT_DAT_FUM&#xA;&#x9;&#x9;,PCT_DAT_ITC&#xA;&#x9;&#x9;,PCT_DAT_FTC&#xA;&#x9;&#x9;,PCT_DAT_ISC&#xA;&#x9;&#x9;,PCT_DAT_FSC&#xA;&#x9;&#x9;,PCT_IND_ATU&#xA;&#x9;&#x9;,PCT_DAT_RTN&#xA;&#x9;&#x9;,PCT_DAT_AUT&#xA;&#x9;&#x9;,PCT_DAT_ORC&#xA;&#x9;&#x9;,PCT_IND_TIP&#xA;&#x9;&#x9;,PCT_IND_SFZ&#xA;&#x9;&#x9;,PCT_TXT_SIT&#xA;&#x9;&#x9;,PCT_TXT_MSR&#xA;&#x9;&#x9;,PCT_IND_ERR&#xA;&#x9;&#x9;,PCT_DSC_XML&#xA;&#x9;&#x9;,PCT_TXT_MSD&#xA;&#x9;&#x9;,PCT_DSC_CHV&#xA;&#x9;&#x9;,PCT_NUM_SCT&#xA;&#x9;&#x9;,PCT_NUM_CTE&#xA;&#x9;&#x9;,PCT_COD_MTR&#xA;&#x9;&#x9;,PCT_DET_MRC&#xA;&#x9;&#x9;,PCT_TIMESTAMP&#xA;&#x9;&#x9;,PCT_IND_ORT&#xA;&#x9;&#x9;,PCT_IND_CNT&#xA;&#x9;&#x9;,PCT_IND_ORC&#xA;&#x9;&#x9;,PCT_IND_CTM&#xA;&#x9;&#x9;,PCT_DAT_ISZ&#xA;&#x9;&#x9;,PCT_DAT_BSC&#xA;&#x9;&#x9;,PCT_IND_RJC&#xA;&#x9;&#x9;,PCT_IND_DEX&#xA;&#x9;&#x9;,PCT_IND_CRT&#xA;&#x9;&#x9;,PCT_DAT_CNT&#xA;&#x9;&#x9;,PCT_CHV_SCB&#xA;&#x9;&#x9;,PCT_NUM_TCFL&#xA;&#x9;&#x9;,PCT_IND_TCG&#xA;&#x9;&#x9;,PCT_IND_ASC&#xA;&#x9;&#x9;,DT_ALTERACAO&#xA;&#x9;FROM UNIFER.PAINEL_CTE&#xA;&#x9;WHERE PCT_TIMESTAMP BETWEEN ? AND ?;&#xA;&#x9;&#xA;    DELETE UNIFER.PAINEL_CTE WHERE PCT_TIMESTAMP  BETWEEN ? AND ? ;&#xA;&#x9;&#xA;END&#xA;&#xA;INSERT INTO replicador.UNIFER_PAINEL_CTE (&#xA;&#x9; [__operation]&#xA;&#x9;,PCT_IDT_PCT&#xA;&#x9;,PCT_IDT_PCT_ORG&#xA;&#x9;,PCG_IDT_PCG&#xA;&#x9;,FX_ID_FLX&#xA;&#x9;,PCT_DAT_IUN&#xA;&#x9;,PCT_DAT_FUN&#xA;&#x9;,PCT_DAT_IUM&#xA;&#x9;,PCT_DAT_FUM&#xA;&#x9;,PCT_DAT_ITC&#xA;&#x9;,PCT_DAT_FTC&#xA;&#x9;,PCT_DAT_ISC&#xA;&#x9;,PCT_DAT_FSC&#xA;&#x9;,PCT_IND_ATU&#xA;&#x9;,PCT_DAT_RTN&#xA;&#x9;,PCT_DAT_AUT&#xA;&#x9;,PCT_DAT_ORC&#xA;&#x9;,PCT_IND_TIP&#xA;&#x9;,PCT_IND_SFZ&#xA;&#x9;,PCT_TXT_SIT&#xA;&#x9;,PCT_TXT_MSR&#xA;&#x9;,PCT_IND_ERR&#xA;&#x9;,PCT_DSC_XML&#xA;&#x9;,PCT_TXT_MSD&#xA;&#x9;,PCT_DSC_CHV&#xA;&#x9;,PCT_NUM_SCT&#xA;&#x9;,PCT_NUM_CTE&#xA;&#x9;,PCT_COD_MTR&#xA;&#x9;,PCT_DET_MRC&#xA;&#x9;,PCT_TIMESTAMP&#xA;&#x9;,PCT_IND_ORT&#xA;&#x9;,PCT_IND_CNT&#xA;&#x9;,PCT_IND_ORC&#xA;&#x9;,PCT_IND_CTM&#xA;&#x9;,PCT_DAT_ISZ&#xA;&#x9;,PCT_DAT_BSC&#xA;&#x9;,PCT_IND_RJC&#xA;&#x9;,PCT_IND_DEX&#xA;&#x9;,PCT_IND_CRT&#xA;&#x9;,PCT_DAT_CNT&#xA;&#x9;,PCT_CHV_SCB&#xA;&#x9;,PCT_NUM_TCFL&#xA;&#x9;,PCT_IND_TCG&#xA;&#x9;,PCT_IND_ASC&#xA;&#x9;,DT_ALTERACAO&#xA;)&#xA;SELECT&#xA;&#x9; 2 AS [__operation]&#xA;&#x9;,PCT_IDT_PCT&#xA;&#x9;,PCT_IDT_PCT_ORG&#xA;&#x9;,PCG_IDT_PCG&#xA;&#x9;,FX_ID_FLX&#xA;&#x9;,PCT_DAT_IUN&#xA;&#x9;,PCT_DAT_FUN&#xA;&#x9;,PCT_DAT_IUM&#xA;&#x9;,PCT_DAT_FUM&#xA;&#x9;,PCT_DAT_ITC&#xA;&#x9;,PCT_DAT_FTC&#xA;&#x9;,PCT_DAT_ISC&#xA;&#x9;,PCT_DAT_FSC&#xA;&#x9;,PCT_IND_ATU&#xA;&#x9;,PCT_DAT_RTN&#xA;&#x9;,PCT_DAT_AUT&#xA;&#x9;,PCT_DAT_ORC&#xA;&#x9;,PCT_IND_TIP&#xA;&#x9;,PCT_IND_SFZ&#xA;&#x9;,PCT_TXT_SIT&#xA;&#x9;,PCT_TXT_MSR&#xA;&#x9;,PCT_IND_ERR&#xA;&#x9;,PCT_DSC_XML&#xA;&#x9;,PCT_TXT_MSD&#xA;&#x9;,PCT_DSC_CHV&#xA;&#x9;,PCT_NUM_SCT&#xA;&#x9;,PCT_NUM_CTE&#xA;&#x9;,PCT_COD_MTR&#xA;&#x9;,PCT_DET_MRC&#xA;&#x9;,PCT_TIMESTAMP&#xA;&#x9;,PCT_IND_ORT&#xA;&#x9;,PCT_IND_CNT&#xA;&#x9;,PCT_IND_ORC&#xA;&#x9;,PCT_IND_CTM&#xA;&#x9;,PCT_DAT_ISZ&#xA;&#x9;,PCT_DAT_BSC&#xA;&#x9;,PCT_IND_RJC&#xA;&#x9;,PCT_IND_DEX&#xA;&#x9;,PCT_IND_CRT&#xA;&#x9;,PCT_DAT_CNT&#xA;&#x9;,PCT_CHV_SCB&#xA;&#x9;,PCT_NUM_TCFL&#xA;&#x9;,PCT_IND_TCG&#xA;&#x9;,PCT_IND_ASC&#xA;&#x9;,?&#xA;FROM UNIFER_STG.PAINEL_CTE&#xA;WHERE NM_OPERACAO &lt;&gt; 'D';&#xA;&#xA;DECLARE @tableVar TABLE (MergeAction VARCHAR(20));&#xA;MERGE UNIFER.PAINEL_CTE AS MyTarget USING   &#xA;(&#xA;SELECT &#x9;&#xA;&#x9;  &#xA;&#x9;&#x9;PCT_IDT_PCT&#xA;&#x9;&#x9;,PCT_IDT_PCT_ORG&#xA;&#x9;&#x9;,PCG_IDT_PCG&#xA;&#x9;&#x9;,FX_ID_FLX&#xA;&#x9;&#x9;,PCT_DAT_IUN&#xA;&#x9;&#x9;,PCT_DAT_FUN&#xA;&#x9;&#x9;,PCT_DAT_IUM&#xA;&#x9;&#x9;,PCT_DAT_FUM&#xA;&#x9;&#x9;,PCT_DAT_ITC&#xA;&#x9;&#x9;,PCT_DAT_FTC&#xA;&#x9;&#x9;,PCT_DAT_ISC&#xA;&#x9;&#x9;,PCT_DAT_FSC&#xA;&#x9;&#x9;,PCT_IND_ATU&#xA;&#x9;&#x9;,PCT_DAT_RTN&#xA;&#x9;&#x9;,PCT_DAT_AUT&#xA;&#x9;&#x9;,PCT_DAT_ORC&#xA;&#x9;&#x9;,PCT_IND_TIP&#xA;&#x9;&#x9;,PCT_IND_SFZ&#xA;&#x9;&#x9;,PCT_TXT_SIT&#xA;&#x9;&#x9;,PCT_TXT_MSR&#xA;&#x9;&#x9;,PCT_IND_ERR&#xA;&#x9;&#x9;,PCT_DSC_XML&#xA;&#x9;&#x9;,PCT_TXT_MSD&#xA;&#x9;&#x9;,PCT_DSC_CHV&#xA;&#x9;&#x9;,PCT_NUM_SCT&#xA;&#x9;&#x9;,PCT_NUM_CTE&#xA;&#x9;&#x9;,PCT_COD_MTR&#xA;&#x9;&#x9;,PCT_DET_MRC&#xA;&#x9;&#x9;,PCT_TIMESTAMP&#xA;&#x9;&#x9;,PCT_IND_ORT&#xA;&#x9;&#x9;,PCT_IND_CNT&#xA;&#x9;&#x9;,PCT_IND_ORC&#xA;&#x9;&#x9;,PCT_IND_CTM&#xA;&#x9;&#x9;,PCT_DAT_ISZ&#xA;&#x9;&#x9;,PCT_DAT_BSC&#xA;&#x9;&#x9;,PCT_IND_RJC&#xA;&#x9;&#x9;,PCT_IND_DEX&#xA;&#x9;&#x9;,PCT_IND_CRT&#xA;&#x9;&#x9;,PCT_DAT_CNT&#xA;&#x9;&#x9;,PCT_CHV_SCB&#xA;&#x9;&#x9;,PCT_NUM_TCFL&#xA;&#x9;&#x9;,PCT_IND_TCG&#xA;&#x9;&#x9;,PCT_IND_ASC&#xA;&#xA;FROM UNIFER_STG.PAINEL_CTE&#xA;where  NM_OPERACAO &lt;&gt; 'D'&#xA;) AS MySource  &#xA;ON  &#xA;&#x9;  &#xA;&#x9; MyTarget.[PCT_IDT_PCT] = MySource.[PCT_IDT_PCT]&#xA;&#x9;   &#xA;WHEN MATCHED THEN   &#xA;UPDATE  &#xA;SET  &#x9;  &#xA;&#x9;   MyTarget.[PCT_IDT_PCT_ORG]     = MySource.[PCT_IDT_PCT_ORG]&#xA;      ,MyTarget.[PCG_IDT_PCG]    = MySource.[PCG_IDT_PCG]&#xA;      ,MyTarget.[FX_ID_FLX]    = MySource.[FX_ID_FLX]&#xA;      ,MyTarget.[PCT_DAT_IUN]   = MySource.[PCT_DAT_IUN]&#xA;      ,MyTarget.[PCT_DAT_FUN]    = MySource.[PCT_DAT_FUN]&#xA;      ,MyTarget.[PCT_DAT_IUM]   = MySource.[PCT_DAT_IUM]&#xA;      ,MyTarget.[PCT_DAT_FUM]   = MySource.[PCT_DAT_FUM]&#xA;      ,MyTarget.[PCT_DAT_ITC]   = MySource.[PCT_DAT_ITC]&#xA;      ,MyTarget.[PCT_DAT_FTC]   = MySource.[PCT_DAT_FTC]&#xA;      ,MyTarget.[PCT_DAT_ISC] &#x9;= MySource.[PCT_DAT_ISC]&#xA;      ,MyTarget.[PCT_DAT_FSC]   = MySource.[PCT_DAT_FSC]&#xA;      ,MyTarget.[PCT_IND_ATU]   = MySource.[PCT_IND_ATU]&#xA;      ,MyTarget.[PCT_DAT_RTN]   = MySource.[PCT_DAT_RTN]&#xA;      ,MyTarget.[PCT_DAT_AUT]   = MySource.[PCT_DAT_AUT]&#