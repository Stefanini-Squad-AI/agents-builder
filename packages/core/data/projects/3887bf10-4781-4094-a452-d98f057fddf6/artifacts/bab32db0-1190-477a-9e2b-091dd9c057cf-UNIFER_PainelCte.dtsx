_CHV_SCB&#xA;&#x9;,PCT_NUM_TCFL&#xA;&#x9;,PCT_IND_TCG&#xA;&#x9;,PCT_IND_ASC&#xA;&#x9;,DT_ALTERACAO&#xA;FROM UNIFER.PAINEL_CTE&#xA;WHERE PCT_IDT_PCT IN (SELECT PCT_IDT_PCT FROM [UNIFER_STG].PAINEL_CTE WHERE NM_OPERACAO = 'D');&#xA;&#xA;DELETE [UNIFER].[PAINEL_CTE]&#xA;WHERE PCT_IDT_PCT IN (SELECT PCT_IDT_PCT FROM [UNIFER_STG].[PAINEL_CTE] WHERE NM_OPERACAO = 'D')   " xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
