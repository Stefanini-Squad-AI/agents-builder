        <SQLTask:SqlTaskData
          SQLTask:Connection="{AB4FF944-CC18-49F8-982C-362EC5C7640A}"
          SQLTask:SqlStatementSource="SELECT &#xA; PACOTE.ST_REPROCESSAMENTO      AS REPROCESSAMENTO,&#xA; PACOTE.ST_PROCESSAMENTO_FULL     AS PROCESSAMENTOFULL,&#xA; GETDATE()          AS DT_INICIO_CARGA,&#xA; PACOTE.DT_CARGA_ANTERIOR      AS DATA_INICIO_REFERENCIA_PROCESSAMENTO,&#xA; --MIN(PACOTE_PREDECESSOR.DT_CARGA_ANTERIOR)  AS DATA_FIM_REFERENCIA_PROCESSAMENTO, &#xA; PACOTE.DT_INICIO_REFERENCIA     AS DATA_INICIO_REFERENCIA_REPROCESSAMENTO,&#xA; PACOTE.DT_FIM_REFERENCIA      AS DATA_FIM_REFERENCIA_REPROCESSAMENTO&#xA;FROM [DBO].[MDEXECUCOESCARGAS] PACOTE &#xA;WHERE &#xA; PACOTE.NM_FLUXO_CARGA = ?&#xA;GROUP BY &#xA; PACOTE.DT_CARGA_ANTERIOR, &#xA; PACOTE.DT_INICIO_CARGA,&#xA; PACOTE.ST_REPROCESSAMENTO,  &#xA; PACOTE.ST_PROCESSAMENTO_FULL,&#xA; PACOTE.dt_inicio_referencia,&#xA; PACOTE.dt_fim_referencia"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="REPROCESSAMENTO"
            SQLTask:DtsVariableName="User::Reprocessamento" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="PROCESSAMENTOFULL"
            SQLTask:DtsVariableName="User::ProcessamentoFull" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="DT_INICIO_CARGA"
            SQLTask:DtsVariableName="User::Data_inicio_execucao" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="DATA_INICIO_REFERENCIA_PROCESSAMENTO"
            SQLTask:DtsVariableName="User::data_inicio_referencia_processamento" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="DATA_INICIO_REFERENCIA_REPROCESSAMENTO"
            SQLTask:DtsVariableName="User::data_inicio_referencia_reprocessamento" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="DATA_FIM_REFERENCIA_REPROCESSAMENTO"
            SQLTask:DtsVariableName="User::data_fim_referencia_reprocessamento" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="System::PackageName"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="-1" />
