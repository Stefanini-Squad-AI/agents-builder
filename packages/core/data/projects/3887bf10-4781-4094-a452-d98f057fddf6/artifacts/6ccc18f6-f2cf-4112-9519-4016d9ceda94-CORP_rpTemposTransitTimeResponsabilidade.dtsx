_percorrido_composicao,&#xA;TT.thr_cd_posicao_distribuida_composicao = STG.thr_cd_posicao_distribuida_composicao,&#xA;TT.thr_qt_vagoes_vazios_composicao = STG.thr_qt_vagoes_vazios_composicao,&#xA;TT.thr_qt_vagoes_carregados_composicao = STG.thr_qt_vagoes_carregados_composicao,&#xA;TT.thr_qt_peso_medio_vagoes_composicao = STG.thr_qt_peso_medio_vagoes_composicao,&#xA;TT.thr_nm_produto_composicao = STG.thr_nm_produto_composicao,&#xA;TT.thr_qt_hp_locomotivas_rebocadas_composicao = STG.thr_qt_hp_locomotivas_rebocadas_composicao,&#xA;TT.thr_qt_hp_total_locomotivas_composicao = STG.thr_qt_hp_total_locomotivas_composicao,&#xA;TT.thr_qt_hp_restrito_locomotivas_tracionadas_composicao = STG.thr_qt_hp_restrito_locomotivas_tracionadas_composicao,&#xA;TT.thr_qt_hp_restrito_locomotivas_rebocadas_composicao = STG.thr_qt_hp_restrito_locomotivas_rebocadas_composicao,&#xA;TT.thr_qt_hp_restrito_total_locomotivas_composicao = STG.thr_qt_hp_restrito_total_locomotivas_composicao,&#xA;TT.thr_qt_hp_disponivel_locomotivas_tracionadas_composicao = STG.thr_qt_hp_disponivel_locomotivas_tracionadas_composicao,&#xA;TT.thr_qt_hp_disponivel_locomotivas_rebocadas_composicao = STG.thr_qt_hp_disponivel_locomotivas_rebocadas_composicao,&#xA;TT.thr_qt_hp_disponivel_total_locomotivas_composicao = STG.thr_qt_hp_disponivel_total_locomotivas_composicao,&#xA;TT.thr_qt_total_locomotivas_composicao = STG.thr_qt_total_locomotivas_composicao,&#xA;TT.thr_ds_modelos_serie_locomotivas_composicao = STG.thr_ds_modelos_serie_locomotivas_composicao,&#xA;TT.thr_ft_velocidade_maxima_alcancavel_classetrem = STG.thr_ft_velocidade_maxima_alcancavel_classetrem,&#xA;TT.thr_cd_hash_chave_update = STG.thr_cd_hash_chave_update&#xA;FROM corp.rpTemposTransitTimeResponsabilidade TT&#xA;JOIN corp_stg.rpTemposTransitTimeResponsabilidade STG &#xA;    ON TT.thr_cd_hash_unique_keys = STG.thr_cd_hash_unique_keys&#xA;WHERE ISNULL(TT.thr_cd_hash_chave_update, '') &lt;&gt; ISNULL(STG.thr_cd_hash_chave_update, '');&#xA;&#xA;&#xA;&#xA;--Inserir registros&#xA;insert into corp.rpTemposTransitTimeResponsabilidade  (thr_cd_ordem_servico&#xA;,thr_cd_prefixo_trem&#xA;,thr_cd_estacao_origem&#xA;,thr_cd_estacao_destino&#xA;,thr_cd_area_operacional&#xA;,thr_dt_origem&#xA;,thr_dt_destino&#xA;,thr_no_tempo_trem_hora_marcha&#xA;,thr_no_tempo_total_transit_time&#xA;,thr_no_tempo_trem_hora_parado&#xA;,thr_no_tempo_trem_hora_parado_aci&#xA;,thr_no_tempo_trem_hora_parado_cco&#xA;,thr_no_tempo_trem_hora_parado_ele&#xA;,thr_no_tempo_trem_hora_parado_loc&#xA;,thr_no_tempo_trem_hora_parado_obr&#xA;,thr_no_tempo_trem_hora_parado_ope&#xA;,thr_no_tempo_trem_hora_parado_pot&#xA;,thr_no_tempo_trem_hora_parado_ptt&#xA;,thr_no_tempo_trem_hora_parado_vag&#xA;,thr_no_tempo_trem_hora_parado_vpe&#xA;,thr_no_tempo_trem_hora_parado_nao_encontrado&#xA;,thr_dt_inclusao_registro&#xA;,thr_dt_alteracao_registro&#xA;,thr_ds_situacao_circulacao_trem&#xA;,thr_sk_empresa_origem_registro&#xA;,thr_ds_empresa_origem_registro&#xA;,thr_cd_ordem_servico_correlata&#xA;,thr_ds_classe_trem&#xA;,thr_cd_classetrem&#xA;,thr_id_composicao&#xA;,thr_dt_formacao_composicao&#xA;,thr_dt_encerramento_composicao&#xA;,thr_qt_na_tu_composicao&#xA;,thr_qt_na_tb_composicao&#xA;,thr_qt_na_paradas_trem&#xA;,thr_qt_na_tkb_composicao&#xA;,thr_vl_consumo_composicao&#xA;,thr_qt_tb_hp_locomotiva&#xA;,thr_vl_percentual_reducao_tracao&#xA;,thr_qt_hp_locomotiva&#xA;,thr_qt_tracionado_locomotiva&#xA;,thr_qt_rebocado_locomotiva&#xA;,thr_no_sequencia_estacao_ordem_servico&#xA;,thr_ds_corredor_origem_ordem_servico&#xA;,thr_vl_comprimento_composicao&#xA;,thr_dt_partida_trem_composicao&#xA;,thr_dt_chegada_trem_composicao&#xA;,thr_ds_corredor_origem_composicao&#xA;,thr_ds_corredor_destino_composicao&#xA;,thr_cd_estacao_origem_composicao&#xA;,thr_cd_estacao_destino_composicao&#xA;,thr_ds_tipo_composicao&#xA;,thr_sn_tracao_isolada_composicao&#xA;,thr_qt_tku_composicao&#xA;,thr_qt_km_percorrido_composicao&#xA;,thr_cd_posicao_distribuida_composicao&#xA;,thr_qt_vagoes_vazios_composicao&#xA;,thr_qt_vagoes_carregados_composicao&#xA;,thr_qt_peso_medio_vagoes_composicao&#xA;,thr_nm_produto_composicao&#xA;,thr_qt_hp_locomotivas_rebocadas_composicao&#xA;,thr_qt_hp_total_locomotivas_composicao&#xA;,thr_qt_hp_restrito_locomotivas_tracionadas_composicao&#xA;,thr_qt_hp_restrito_locomotivas_rebocadas_composicao&#xA;,thr_qt_hp_restrito_total_locomotivas_composicao&#xA;,thr_qt_hp_disponivel_locomotivas_tracionadas_composicao&#xA;,thr_qt_hp_disponivel_locomotivas_rebocadas_composicao&#xA;,thr_qt_hp_disponivel_total_locomotivas_composicao&#xA;,thr_qt_total_locomotivas_composicao&#xA;,thr_ds_modelos_serie_locomotivas_composicao&#xA;,thr_ft_velocidade_maxima_alcancavel_classetrem&#xA;,thr_cd_hash_unique_keys&#xA;,thr_cd_hash_chave_update)&#xA;select &#xA; STG.thr_cd_ordem_servico&#xA;,STG.thr_cd_prefixo_trem&#xA;,STG.thr_cd_estacao_origem&#xA;,STG.thr_cd_estacao_destino&#xA;,STG.thr_cd_area_operacional&#xA;,STG.thr_dt_origem&#xA;,STG.thr_dt_destino&#xA;,STG.thr_no_tempo_trem_hora_marcha&#xA;,STG.thr_no_tempo_total_transit_time&#xA;,STG.thr_no_tempo_trem_hora_parado&#xA;,STG.thr_no_tempo_trem_hora_parado_aci&#xA;,STG.thr_no_tempo_trem_hora_parado_cco&#xA;,STG.thr_no_tempo_trem_hora_parado_ele&#xA;,STG.thr_no_tempo_trem_hora_parado_loc&#xA;,STG.thr_no_tempo_trem_hora_parado_obr&#xA;,STG.thr_no_tempo_trem_hora_parado_ope&#xA;,STG.thr_no_tempo_trem_hora_parado_pot&#xA;,STG.thr_no_tempo_trem_hora_parado_ptt&#xA;,STG.thr_no_tempo_trem_hora_parado_vag&#xA;,STG.thr_no_tempo_trem_hora_parado_vpe&#xA;,STG.thr_no_tempo_trem_hora_parado_nao_encontrado&#xA;,STG.thr_dt_inclusao_registro&#xA;,STG.thr_dt_alteracao_registro&#xA;,STG.thr_ds_situacao_circulacao_trem&#xA;,STG.thr_sk_empresa_origem_registro&#xA;,STG.thr_ds_empresa_origem_registro&#xA;,STG.thr_cd_ordem_servico_correlata&#xA;,STG.thr_ds_classe_trem&#xA;,STG.thr_cd_classetrem&#xA;,STG.thr_id_composicao&#xA;,STG.thr_dt_formacao_composicao&#xA;,STG.thr_dt_encerramento_composicao&#xA;,STG.thr_qt_na_tu_composicao&#xA;,STG.thr_qt_na_tb_composicao&#xA;,STG.thr_qt_na_paradas_trem&#xA;,STG.thr_qt_na_tkb_composicao&#xA;,STG.thr_vl_consumo_composicao&#xA;,STG.thr_qt_tb_hp_locomotiva&#xA;,STG.thr_vl_percentual_reducao_tracao&#xA;,STG.thr_qt_hp_locomotiva&#xA;,STG.thr_qt_tracionado_locomotiva&#xA;,STG.thr_qt_rebocado_locomotiva&#xA;,STG.thr_no_sequencia_estacao_ordem_servico&#xA;,STG.thr_ds_corredor_origem_ordem_servico&#xA;,STG.thr_vl_comprimento_composicao&#xA;,STG.thr_dt_partida_trem_composicao&#xA;,STG.thr_dt_chegada_trem_composicao&#xA;,STG.thr_ds_corredor_origem_composicao&#xA;,STG.thr_ds_corredor_destino_composicao&#xA;,STG.thr_cd_estacao_origem_composicao&#xA;,STG.thr_cd_estacao_destino_composicao&#xA;,STG.thr_ds_tipo_composicao&#xA;,STG.thr_sn_tracao_isolada_composicao&#xA;,STG.thr_qt_tku_composicao&#xA;,STG.thr_qt_km_percorrido_composicao&#xA;,STG.thr_cd_posicao_distribuida_composicao&#xA;,STG.thr_qt_vagoes_vazios_composicao&#xA;,STG.thr_qt_vagoes_carregados_composicao&#xA;,STG.thr_qt_peso_medio_vagoes_composicao&#xA;,STG.thr_nm_produto_composicao&#xA;,STG.thr_qt_hp_locomotivas_rebocadas_composicao&#xA;,STG.thr_qt_hp_total_locomotivas_composicao&#xA;,STG.thr_qt_hp_restrito_locomotivas_tracionadas_composicao&#xA;,STG.thr_qt_hp_restrito_locomotivas_rebocadas_composicao&#xA;,STG.thr_qt_hp_restrito_total_locomotivas_composicao&#xA;,STG.thr_qt_hp_disponivel_locomotivas_tracionadas_composicao&#xA;,STG.thr_qt_hp_disponivel_locomotivas_rebocadas_composicao&#xA;,STG.thr_qt_hp_disponivel_total_locomotivas_composicao&#xA;,STG.thr_qt_total_locomotivas_composicao&#xA;,STG.thr_ds_modelos_serie_locomotivas_composicao&#xA;,STG.thr_ft_velocidade_maxima_alcancavel_classetrem&#xA;,STG.thr_cd_hash_unique_keys&#xA;,STG.thr_cd_hash_chave_update&#xA;&#xA;FROM corp_stg.rpTemposTransitTimeResponsabilidade STG&#xA;LEFT JOIN corp.rpTemposTransitTimeResponsabilidade TT ON STG.thr_cd_hash_unique_keys = TT.thr_cd_hash_unique_keys &#xA;WHERE TT.thr_cd_hash_unique_keys IS NULL;&#xA;&#xA;&#xA;-- Deletar Registros&#xA;&#xA;DELETE TT&#xA;FROM corp.rpTemposTransitTimeResponsabilidade TT&#xA;LEFT JOIN corp_stg.rpTemposTransitTimeResponsabilidade STG ON TT.thr_cd_hash_unique_keys = STG.thr_cd_hash_unique_keys&#xA;WHERE STG.thr_cd_hash_unique_keys IS NULL;&#xA;  " xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="User::Data_inicio_execucao"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="7"
            SQLTask:ParameterSize="-1" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="1"
            SQLTask:DtsVariableName="User::ProcessamentoFull"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="131"
            SQLTask:ParameterSize="-1" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="2"
            SQLTask:DtsVariableName="User::Reprocessamento"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="131"
            SQLTask:ParameterSize="-1" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="3"
            SQLTask:DtsVariableName="User::data_inicio_referencia_reprocessamento"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="7"
            SQLTask:ParameterSize="-1" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="4"
            SQLTask:DtsVariableName="User::data_fim_referencia_reprocessamento"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="7"
            SQLTask:ParameterSize="-1" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\ESQL_CargaReport_Incremental"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{d07e16bc-d429-4547-af00-83f475b18a18}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="ESQL_CargaReport_Incremental"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{6CC07B41-9A45-4746-96E7-6B8CDAA39323}"
          SQLTask:SqlStatementSource="DECLARE @dataProcessamento DATE = ?&#xA;DECLARE @dataInicio DATE&#xA;DECLARE @dataFim DATE&#xA;DECLARE @FULL INT = ?&#xA;DECLARE @REPROCESSAMENTO INT = ?;&#xA;&#xA;--IF @FULL = 0&#xA;--BEGIN&#xA;&#xA;--SET @dataInicio = (SELECT MIN(ttt_dt_origem) FROM corp.rpTemposTransitTime)&#xA;--SET @dataFim = @dataProcessamento; --dataBancoSSIS&#xA;--TRUNCATE TABLE corp.rpTemposTransitTimeResponsabilidade&#xA;&#xA;--END&#xA;&#xA;&#xA;&#xA;IF @REPROCESSAMENTO = 1&#xA;&#xA;BEGIN&#xA;SET @dataInicio = ?&#xA;SET @dataFim = ?&#xA;DELETE FROM corp.rpTemposTransitTimeResponsabilidade WHERE thr_dt_destino BETWEEN @dataInicio AND @dataFim&#xA;&#xA;END&#xA;;&#xA;&#xA;&#xA;SELECT &#xA;&#x9;tha_sk_ordem_servico_trem,&#xA;&#x9;tha_sk_classe_trem,&#xA;&#x9;--IIF(thp_sk_secao_bloqueio_ferrovia = -2, NULL, thp_sk_secao_bloqueio_ferrovia) AS thp_sk_secao_bloqueio_ferrovia,&#xA;&#x9;tha_sk_area_operacional,&#xA;&#x9;tha_sk_area_operacional_parada,&#xA;&#x9;tha_sk_trem,&#xA;&#x9;tha_sk_grupo_responsavel_parada_trem,&#xA;&#x9;tha_sk_motivo_parada_trem,&#xA;&#x9;tha_no_tempo_trem_hora_parado,&#xA;&#x9;DATA_ORIGEM.dat_dt_data + CAST(tha_sk_hr_inicio_parada_trem AS DATETIME) DataHoraInicioThp,&#xA;&#x9;DATA_DESTINO.dat_dt_data + CAST(tha_sk_hr_fim_parada_trem AS DATETIME) AS DataHoraFimThp&#xA;INTO #THP&#xA;FROM corp.fdTremHoraParadoAreasOperacionais WITH (NOLOCK)&#xA;JOIN gbl.mdDatas dataPos WITH (NOLOCK) ON dataPos.dat_no_ano_mes_dia = tha_sk_dt_inicio_parada_trem &#xA;JOIN gbl.mdDatas DATA_ORIGEM WITH (NOLOCK) ON  DATA_ORIGEM.dat_no_ano_mes_dia = tha_sk_dt_inicio_parada_trem&#xA;JOIN gbl.mdDatas DATA_DESTINO WITH (NOLOCK) ON  DATA_DESTINO.dat_no_ano_mes_dia = tha_sk_dt_fim_parada_trem&#xA;--WHERE THA_SK_REGISTRO_ALTERADO = 1&#xA; ;&#xA;&#xA;&#xA;SELECT distinct&#xA;&#x9;ttm_sk_ordem_servico_trem,&#xA;&#x9;ttm_sk_classe_trem,&#xA;&#x9;ttm_sk_estacao_origem,&#xA;&#x9;ttm_sk_estacao_destino,&#xA;&#x9;ttm_sk_area_operacional,&#xA;&#x9;ttm_sk_trem,&#xA;&#x9;ttm_no_tempo_transit_time,&#xA;&#x9;ttm_sk_situacao_circulacao_trem,&#xA;&#x9;DATA_ORIGEM.dat_dt_data + CAST(ttm_sk_hr_saida_origem_trem AS DATETIME) AS DataHoraOrigem,&#xA;&#x9;DATA_DESTINO.dat_dt_data + CAST(ttm_sk_hr_chegada_destino_trem AS DATETIME) AS DataHoraDestino&#xA;INTO #TRANSIT_TIME&#xA;FROM corp.fdTransitTimeAreasOperacionais WITH (NOLOCK)&#xA;JOIN gbl.mdDatas DATA_ORIGEM WITH (NOLOCK) ON  DATA_ORIGEM.dat_no_ano_mes_dia = ttm_sk_dt_saida_origem_trem&#xA;JOIN gbl.mdDatas DATA_DESTINO WITH (NOLOCK) ON  DATA_DESTINO.dat_no_ano_mes_dia = ttm_sk_dt_chegada_destino_trem&#xA;;&#xA;&#xA;SELECT  &#xA;&#x9;ost_no_ordem_servico_trem AS CodigoOrdemServico,&#xA;&#x9;ost_no_ordem_servico_correlata AS CodigoOrdemServicoCorrelata,&#xA;&#x9;CASE &#xA;&#x9;when C.ctg_cd_classetrem = 'A' THEN 'AUTO DE LINHA'&#xA;&#x9;When C.ctg_cd_classetrem = 'B' THEN 'AUTO DE LINHA'&#xA;&#x9;when C.ctg_cd_classetrem = 'C' THEN 'CARGUEIRO'&#xA;&#x9;when C.ctg_cd_classetrem = 'D' THEN 'COMBUSTÍVEIS'&#xA;&#x9;when C.ctg_cd_classetrem = 'E' THEN 'EXPRESSO'&#xA;&#x9;when C.ctg_cd_classetrem = 'F' THEN 'VEÍCULO RODOFERROV'&#xA;&#x9;when C.ctg_cd_classetrem = 'G' THEN 'MINÉRIO VAGÃO C G'&#xA;&#x9;when C.ctg_cd_classetrem = 'H' THEN 'HELP'&#xA;&#x9;when C.ctg_cd_classetrem = 'I' THEN 'INSPEÇÃO'&#xA;&#x9;when C.ctg_cd_classetrem = 'J' THEN 'GRÃOS'&#xA;&#x9;when C.ctg_cd_classetrem = 'K' THEN 'CARVÃO'&#xA;&#x9;when C.ctg_cd_classetrem = 'L' THEN 'ESCOTEIRA'&#xA;&#x9;when C.ctg_cd_classetrem = 'M' THEN 'MINÉRIO'&#xA;&#x9;when C.ctg_cd_classetrem = 'O' THEN 'TREM ESPECIAL'&#xA;&#x9;when C.ctg_cd_classetrem = 'P' THEN 'PASSAGEIRO'&#xA;&#x9;when C.ctg_cd_classetrem = 'Q' Then 'AÇUCAR'&#xA;&#x9;when C.ctg_cd_classetrem = 'R' THEN 'EQUIPAMENTO VP'&#xA;&#x9;when C.ctg_cd_classetrem = 'S' THEN 'SOCORRO'&#xA;&#x9;when C.ctg_cd_classetrem = 'T' THEN 'TRILHEIRO'&#xA;&#x9;when C.ctg_cd_classetrem = 'V' THEN 'SERVIÇO INTERNO'--US 264063&#xA;&#x9;when C.ctg_cd_classetrem = 'W' THEN 'MANOBRAS'&#xA;&#x9;when C.ctg_cd_classetrem = 'X' THEN 'PRODUTOS QUÍMICOS'&#xA;&#x9;when C.ctg_cd_classetrem = 'Y' THEN 'CIMENTO'--US 264063&#xA;&#x9;END AS DescricaoClasseTrem,&#xA;&#x9;ttm_sk_ordem_servico_trem,&#xA;&#x9;tre_cd_prefixo_trem AS CodigoPrefixoTrem,&#xA;&#x9;AO.aro_cd_areaoperacional AS AreaOperacional, &#xA;&#x9;AOP.eso_cd_estacao_origem as CodigoEstacaoOrigem,&#xA;&#x9;AOPD.esd_cd_estacao_destino as CodigoEstacaoDestino, &#xA;&#x9;DataHoraOrigem,&#xA;&#x9;DataHoraDestino,&#xA;&#x9;DataHoraInicioThp,&#xA;&#x9;DataHoraFimThp,&#xA;&#x9;ttm_no_tempo_transit_time - ISNULL(THP.tha_no_tempo_trem_hora_parado,0) AS TremHoraMarcha,&#xA;&#x9;ISNULL(THP.tha_no_tempo_trem_hora_parado,0) AS TremHoraParado,&#xA;&#x9;ISNULL(ttm_no_tempo_transit_time,0) AS TransitTime,&#xA;&#x9;rmt_cd_grupo_responsavel AS CodigoGrupoResponsabilidadeParada,&#xA;&#x9;mpt_ds_motivo_parada_trem AS DescricaoMotivoParadaTrem,&#xA;&#x9;sct_ds_situacao_circulacao_trem AS DescricaoSituacaoTrem,&#xA;&#x9;C.ctg_ft_velocidade_maxima_admissivel_classetrem AS VMAClasseTrem, --US 264063&#xA;&#x9;C.ctg_cd_classetrem AS CodigoClasseTrem&#xA;INTO #THP_THM&#xA;FROM #TRANSIT_TIME &#xA;LEFT JOIN #THP THP ON  (THP.tha_sk_ordem_servico_trem = ttm_sk_ordem_servico_trem&#xA;&#x9;AND ((ttm_sk_area_operacional = THP.tha_sk_area_operacional_parada) OR (ttm_sk_area_operacional = THP.tha_sk_area_operacional))&#xA;&#x9;AND ttm_sk_trem = THP.tha_sk_trem)&#xA;LEFT JOIN OPF.mdClassesTrem AS C WITH (NOLOCK) ON C.ctg_sk_classetrem =  ttm_sk_classe_trem&#xA;LEFT JOIN corp.mdOrdensServicoTrem OST WITH (NOLOCK) ON  ost_sk_ordem_servico_trem = ttm_sk_ordem_servico_trem&#xA;LEFT JOIN corp.mdTrens TREM WITH (NOLOCK) ON  TREM.tre_sk_trem = ost_sk_trem&#xA;LEFT JOIN CORP.mdSituacoesCirculacaoTrem SCT ON SCT.sct_sk_situacao_circulacao_trem = ttm_sk_situacao_circulacao_trem&#xA;LEFT JOIN opf.mdAreasOperacionais AO ON AO.aro_sk_areaoperacional = ttm_sk_area_operacional&#xA;LEFT JOIN corp.mdEstacoesOrigem AOP  ON AOP.eso_sk_estacao_origem = ttm_sk_estacao_origem&#xA;LEFT JOIN corp.mdEstacoesDestino AOPD ON AOPD.esd_sk_estacao_destino = ttm_sk_estacao_destino&#xA;LEFT JOIN corp.mdResponsaveisMotivosParadasTrem WITH (NOLOCK) ON  rmt_sk_responsavel = tha_sk_grupo_responsavel_parada_trem&#xA;LEFT JOIN corp.mdMotivosParadasTrem WITH (NOLOCK) ON  mpt_sk_motivo_parada_trem = tha_sk_motivo_parada_trem&#xA;Where 1 = 1;&#xA;&#xA;&#xA; &#xA;SELECT Distinct&#xA;&#x9;ttm_sk_ordem_servico_trem AS tsb_sk_ordem_servico_trem&#xA;INTO #TRENS&#xA;FROM #THP_THM;&#xA;&#xA;&#xA;SELECT&#xA;&#x9;CodigoOrdemServico,&#xA;&#x9;CodigoOrdemServicoCorrelata,&#xA;&#x9;DescricaoClasseTrem,&#xA;&#x9;CodigoPrefixoTrem,&#xA;&#x9;AreaOperacional,&#xA;&#x9;CodigoEstacaoOrigem,&#xA;&#x9;CodigoEstacaoDestino,&#xA;&#x9;--DataHoraInicioThp,&#xA;&#x9;--DataHoraFimThp,&#xA;&#x9;DataHoraOrigem,&#xA;&#x9;DataHoraDestino,&#xA;&#x9;CodigoGrupoResponsabilidadeParada,&#xA;&#x9;CodigoGrupoResponsabilidadeParada as CodigoGrupoResponsabilidade,&#xA;&#x9;DescricaoMotivoParadaTrem,&#xA;&#x9;(TransitTime - SUM(TremHoraParado)) AS TempoEmMarchaEmHoras, -- alteração bug 210804&#xA;&#x9;--SUM(TremHoraMarcha) AS TempoEmMarchaEmHoras, -- alteração bug 210804&#xA;&#x9;SUM(TremHoraParado) AS  TempoParadoEmHorasPivot,&#xA;&#x9;SUM(TremHoraParado) AS TempoParadoEmHoras,&#xA;&#x9;-- SUM(TransitTime) AS TransitTime  -- alteração bug 210804&#xA;&#x9;TransitTime AS TransitTime, -- alteração bug 210804&#xA;&#x9;DescricaoSituacaoTrem,&#xA;&#x9;VMAClasseTrem,&#xA;&#x9;CodigoClasseTrem--US 264063&#xA;INTO #BASE_THM_THP&#xA;FROM #THP_THM THP_THM&#xA;INNER JOIN #TRENS t ON  t.tsb_sk_ordem_servico_trem = THP_THM.ttm_sk_ordem_servico_trem&#xA;GROUP BY&#xA;&#x9;CodigoOrdemServico,&#xA;&#x9;CodigoOrdemServicoCorrelata,&#xA;&#x9;DescricaoClasseTrem,&#xA;&#x9;CodigoPrefixoTrem,&#xA;&#x9;AreaOperacional,&#xA;&#x9;CodigoEstacaoOrigem,&#xA;&#x9;CodigoEstacaoDestino,&#xA;&#x9;--DataHoraInicioThp,&#xA;&#x9;--DataHoraFimThp,&#xA;&#x9;DataHoraOrigem,&#xA;&#x9;DataHoraDestino,&#xA;&#x9;CodigoGrupoResponsabilidadeParada,&#xA;&#x9;DescricaoMotivoParadaTrem,&#xA;&#x9;TransitTime,&#xA;&#x9;DescricaoSituacaoTrem,&#xA;&#x9;VMAClasseTrem, --US 264063;&#xA;&#x9;CodigoClasseTrem&#xA; &#xA;&#xA;SELECT&#xA;&#x9;CodigoOrdemServico,&#xA;&#x9;CodigoOrdemServicoCorrelata,&#xA;&#x9;DescricaoClasseTrem,&#xA;&#x9;CodigoPrefixoTrem,&#xA;&#x9;CodigoEstacaoOrigem,&#xA;&#x9;CodigoEstacaoDestino,&#xA;&#x9;AreaOperacional,&#xA;&#x9;DataHoraOrigem,&#xA;&#x9;DataHoraDestino,&#xA;&#x9;--CodigoGrupoResponsabilidadeParada,&#xA;&#x9;--DescricaoMotivoParadaTrem,&#xA;&#x9;DescricaoSituacaoTrem,&#xA;&#x9;TempoEmMarchaEmHoras As TremHoraMarcha,&#xA;&#x9;TempoParadoEmHoras,&#xA;&#x9;TempoParadoEmHoras AS TempoParadoEmHorasPivot,&#xA;&#x9;TempoParadoEmHoras AS TremHoraParado,&#xA;&#x9;TransitTime AS TransitTime,&#xA;&#x9;ISNULL([ACI],  0) 'thr_no_tempo_trem_hora_parado_aci',&#xA;&#x9;ISNULL([CCO],  0) 'thr_no_tempo_trem_hora_parado_cco',&#xA;&#x9;ISNULL([ELE],  0) 'thr_no_tempo_trem_hora_parado_ele',&#xA;&#x9;ISNULL([LOC],  0) 'thr_no_tempo_trem_hora_parado_loc',&#xA;&#x9;ISNULL([OBR],  0) 'thr_no_tempo_trem_hora_parado_obr',&#xA;&#x9;ISNULL([OPE],  0) 'thr_no_tempo_trem_hora_parado_ope',&#xA;&#x9;ISNULL([POT],   0) 'thr_no_tempo_trem_hora_parado_pot',&#xA;&#x9;ISNULL([PTT],  0) 'thr_no_tempo_trem_hora_parado_ptt',&#xA;&#x9;ISNULL([VAG],  0) 'thr_no_tempo_trem_hora_parado_vag',&#xA;&#x9;ISNULL([VPE],  0) 'thr_no_tempo_trem_hora_parado_vpe',&#xA;&#x9;ISNULL([Nao_Preenchido], 0) 'thr_no_tempo_trem_hora_parado_nao_preenchido',&#xA;&#x9;VMAClasseTrem, --US 264063&#xA;&#x9;CodigoClasseTrem&#xA;INTO #BASEPIVOT&#xA;FROM #BASE_THM_THP BASE_THM_THP PIVOT (SUM(TempoParadoEmHorasPivot) &#xA;&#x9;FOR BASE_THM_THP.CodigoGrupoResponsabilidadeParada IN([ACI], [CCO], [ELE], [LOC], [OBR], [OPE], [POT], [PTT], [VAG], [VPE],  [Nao_Preenchido]) ) PivotTable;&#xA;&#xA;&#xA;-- Retira registros duplicados em função do campo CodigoOrdemServicoCorrelata = -2 - BUG: 217549&#xA;SELECT &#xA;&#x9;ISNULL(CodigoOrdemServico,-2) as thr_cd_ordem_servico,&#xA;&#x9;ISNULL(CodigoOrdemServicoCorrelata,-2) as thr_cd_ordem_servico_correlata,&#xA;&#x9;ISNULL(DescricaoClasseTrem,'NÃO ENCONTRADA') as thr_ds_classe_trem,&#xA;&#x9;ISNULL(CodigoPrefixoTrem,'-2') as thr_cd_prefixo_trem,&#xA;&#x9;ISNULL(CodigoEstacaoOrigem,'-2') as thr_cd_estacao_origem,&#xA;&#x9;ISNULL(CodigoEstacaoDestino,'-2') as thr_cd_estacao_destino,&#xA;&#x9;ISNULL(AreaOperacional,'NÃO ENCONTRADO') as thr_cd_area_operacional,&#xA;&#x9;ISNULL(DescricaoSituacaoTrem,'NÃO ENCONTRADO') as thr_ds_situacao_circulacao_trem,&#xA;&#x9;ISNULL(DataHoraOrigem,'1900-01-01 00:00:00') as thr_dt_origem,&#xA;&#x9;ISNULL(DataHoraDestino,'1900-01-01 00:00:00') as thr_dt_destino,&#xA;&#x9;SUM(TremHoraParado) as thr_no_tempo_trem_hora_parado,&#xA;&#x9;max(TransitTime) - SUM(TremHoraParado) as thr_no_tempo_trem_hora_marcha ,&#xA;&#x9;max(TransitTime) as thr_no_tempo_total_transit_time,&#xA;&#x9;SUM(thr_no_tempo_trem_hora_parado_aci) as thr_no_tempo_trem_hora_parado_aci,&#xA;&#x9;SUM(thr_no_tempo_trem_hora_parado_cco) as thr_no_tempo_trem_hora_parado_cco,&#xA;&#x9;SUM(thr_no_tempo_trem_hora_parado_ele) as thr_no_tempo_trem_hora_parado_ele,&#xA;&#x9;SUM(thr_no_tempo_trem_hora_parado_loc) as thr_no_tempo_trem_hora_parado_loc,&#xA;&#x9;SUM(thr_no_tempo_trem_hora_parado_obr) as thr_no_tempo_trem_hora_parado_obr,&#xA;&#x9;SUM(thr_no_tempo_trem_hora_parado_ope) as thr_no_tempo_trem_hora_parado_ope,&#xA;&#x9;SUM(thr_no_tempo_trem_hora_parado_pot) as thr_no_tempo_trem_hora_parado_pot,&#xA;&#x9;SUM(thr_no_tempo_trem_hora_parado_ptt) as thr_no_tempo_trem_hora_parado_ptt,&#xA;&#x9;SUM(thr_no_tempo_trem_hora_parado_vag) as thr_no_tempo_trem_hora_parado_vag,&#xA;&#x9;SUM(thr_no_tempo_trem_hora_parado_vpe) as thr_no_tempo_trem_hora_parado_vpe,&#xA;&#x9;SUM(thr_no_tempo_trem_hora_parado_nao_preenchido) as thr_no_tempo_trem_hora_parado_nao_encontrado,&#xA;&#x9;@dataProcessamento AS thr_dt_inclusao_registro,&#xA;&#x9;@dataProcessamento AS thr_dt_alteracao_registro,&#xA;&#x9;1 AS thr_sk_empresa_origem_registro,&#xA;&#x9;'VLI' AS thr_ds_empresa_origem_registro,&#xA;&#x9;ROW_NUMBER() OVER(PARTITION BY CodigoOrdemServico, CodigoPrefixoTrem, CodigoEstacaoOrigem, CodigoEstacaoDestino, DataHoraOrigem, DataHoraDestino ,&#xA;&#x9;AreaOperacional ORDER BY CodigoOrdemServicoCorrelata desc) AS CONT,&#xA;&#x9;ISNULL(VMAClasseTrem, -2) AS thr_ft_velocidade_maxima_alcancavel_classetrem, --US 264063&#xA;&#x9;ISNULL(CodigoClasseTrem,-2) as thr_cd_classetrem&#xA;INTO #RETIRADUPLICADOS&#xA;FROM #BASEPIVOT &#xA;where 1 = 1&#xA;GROUP BY&#xA;&#x9;CodigoOrdemServico,&#xA;&#x9;CodigoOrdemServicoCorrelata,&#xA;&#x9;DescricaoClasseTrem,&#xA;&#x9;CodigoPrefixoTrem,&#xA;&#x9;CodigoEstacaoOrigem,&#xA;&#x9;CodigoEstacaoDestino,&#xA;&#x9;AreaOperacional,&#xA;&#x9;DescricaoSituacaoTrem,&#xA;&#x9;DataHoraOrigem,&#xA;&#x9;DataHoraDestino,&#xA;&#x9;VMAClasseTrem,&#xA;&#x9;ISNULL(CodigoClasseTrem,-2);&#xA;&#xA;/*&#xA;*&#x9;248717 - [DW-CI] [OKR1-KR05-2025] [Novo Indicador] - Report para Transit Time com informações aderência trem tipo (TB ; HP,TB/HP)&#x9;&#xA;*&#xA;*&#x9;Realiza o agrupamento dos dados, referente à composição e locomotiva, que estão presentes na rpAderenciaTremTipoLocomotivas&#xA;*&#x9;Os indicadores TU, TB, QT_PARADAS_TREM, TKB, VL_CONSUMO_COMPOSIÇÃO não são agregáveis pois a granularidade já está em relação à composição&#xA;*&#xA;*&#x9;Os indicadores relacionados às locomotivas são agregáveis.&#xA;*&#x9;O indicador vl_percentual_reducao_tracao faz uma média da porcentagem das locomotivas tracionadas&#xA;*&#x9;O indicador qt_hp_locomotiva é somado apenas para as locomotivas tracionadas&#xA;*/ &#xA;&#xA;SELECT &#xA;&#x9;atl_no_ordem_servico_trem&#xA;&#x9;,atl_cd_prefixo_trem&#xA;&#x9;,atl_cd_classetrem&#xA;&#x9;,atl_id_composicao&#xA;&#x9;,atl_dt_formacao_composicao&#xA;&#x9;,atl_dt_encerramento_composicao&#xA;&#x9;,AVG(atl_qt_tu_composicao)&#x9;&#x9;&#x9;&#x9;AS atl_qt_tu_composicao&#xA;&#x9;,AVG(atl_qt_tb_composicao)&#x9;&#x9;&#x9;&#x9;AS atl_qt_tb_composicao&#x9;&#x9;&#xA;&#x9;,AVG(atl_qt_paradas_trem)&#x9;&#x9;&#x9;&#x9;AS atl_qt_paradas_trem&#xA;&#x9;,AVG(atl_qt_tkb_composicao)&#x9;&#x9;&#x9;&#x9;AS atl_qt_tkb_composicao&#xA;&#x9;,AVG(atl_vl_consumo_composicao)&#x9;&#x9;&#x9;AS atl_vl_consumo_composicao&#xA;&#x9;,AVG(CASE WHEN atl_ds_tracionado_rebocado = 'Tracionado' THEN atl_vl_percentual_reducao_tracao END)  AS atl_vl_percentual_reducao_tracao&#xA;&#x9;,SUM(CASE WHEN atl_ds_tracionado_rebocado = 'Tracionado' THEN atl_qt_hp_locomotiva END) AS atl_qt_hp_locomotiva&#xA;&#x9;,COUNT(CASE WHEN atl_ds_tracionado_rebocado = 'Tracionado' THEN 1 END) AS atl_qt_tracionado_locomotiva&#xA;&#x9;,COUNT(CASE WHEN atl_ds_tracionado_rebocado = 'Rebocado' THEN 1 END) AS atl_qt_rebocado_locomotiva&#xA;INTO #ADERENCIA&#xA;FROM CORP.rpAderenciaTremTipoLocomotivas&#xA;GROUP BY &#xA;&#x9;atl_no_ordem_servico_trem&#xA;&#x9;,atl_cd_prefixo_trem&#xA;&#x9;,atl_cd_classetrem&#xA;&#x9;,atl_id_composicao&#xA;&#x9;,atl_dt_formacao_composicao&#xA;&#x9;,atl_dt_encerramento_composicao&#xA;&#xA;/*&#xA;*&#x9;ADICIONA A COLUNA dt_media e filtra os registros duplicados&#xA;*&#x9;&#xA;*&#x9;A coluna dt_media é a media entre dt_origem e dt_destino e é utilizada como chave no join com a rpAderenciaTremTipoLocomotivas&#xA;*/&#xA;SELECT &#xA;&#x9;thr_cd_ordem_servico,&#xA;&#x9;thr_cd_ordem_servico_correlata,&#xA;&#x9;thr_ds_classe_trem,&#xA;&#x9;thr_cd_prefixo_trem,&#xA;&#x9;thr_cd_estacao_origem,&#xA;&#x9;thr_cd_estacao_destino,&#xA;&#x9;thr_cd_area_operacional,&#xA;&#x9;thr_ds_situacao_circulacao_trem,&#xA;&#x9;thr_dt_origem,&#xA;&#x9;thr_dt_destino,&#xA;&#x9;thr_no_tempo_trem_hora_parado,&#xA;&#x9;thr_no_tempo_trem_hora_marcha ,&#xA;&#x9;thr_no_tempo_total_transit_time,&#xA;&#x9;thr_no_tempo_trem_hora_parado_aci,&#xA;&#x9;thr_no_tempo_trem_hora_parado_cco,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ele,&#xA;&#x9;thr_no_tempo_trem_hora_parado_loc,&#xA;&#x9;thr_no_tempo_trem_hora_parado_obr,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ope,&#xA;&#x9;thr_no_tempo_trem_hora_parado_pot,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ptt,&#xA;&#x9;thr_no_tempo_trem_hora_parado_vag,&#xA;&#x9;thr_no_tempo_trem_hora_parado_vpe,&#xA;&#x9;thr_no_tempo_trem_hora_parado_nao_encontrado,&#xA;&#x9;thr_dt_inclusao_registro,&#xA;&#x9;thr_dt_alteracao_registro,&#xA;&#x9;thr_sk_empresa_origem_registro,&#xA;&#x9;thr_ds_empresa_origem_registro,&#xA;&#x9;CASE WHEN thr_dt_origem &lt; '2000-01-01' THEN thr_dt_destino&#xA;&#x9;&#x9;&#x9;  WHEN thr_dt_destino &lt; '2000-01-01' THEN thr_dt_origem&#xA;&#x9;&#x9;&#x9;  ELSE (DATEADD(SECOND, DATEDIFF(SECOND, thr_dt_origem, thr_dt_destino) / 2, thr_dt_origem))&#xA;&#x9;END AS thr_dt_media,&#xA;&#x9;thr_ft_velocidade_maxima_alcancavel_classetrem,&#xA;&#x9;thr_cd_classetrem--US 264063&#xA;&#xA;INTO #TT_DTMEDIA&#xA;from #RETIRADUPLICADOS&#xA;WHERE CONT = 1&#xA;&#xA;--Abaixo novas colunas da rpAderenciaTremTipoComposicaoSerie adicionadas na estória 261633 &#xA;Select &#xA;&#x9;ats_id_composicao&#xA;&#x9;,ats_vl_comprimento_composicao&#xA;&#x9;,ats_dt_partida_trem&#xA;&#x9;,ats_dt_chegada_trem&#xA;&#x9;,ats_ds_corredor_origem_os&#xA;&#x9;,ats_ds_corredor_origem_composicao&#xA;&#x9;,ats_ds_corredor_destino_composicao&#xA;&#x9;,ats_cd_estacao_origem_composicao&#xA;&#x9;,ats_cd_estacao_destino_composicao&#xA;&#x9;,ats_ds_tipo_composicao&#xA;&#x9;,ats_sn_tracao_isolada&#xA;&#x9;,ats_qt_tku_composicao&#xA;&#x9;,ats_qt_km_percorrido&#xA;&#x9;&#xA;&#x9;,ats_cd_posicao_distribuida&#xA;&#x9;,ats_qt_vagoes_vazios&#xA;&#x9;,ats_qt_vagoes_carregados&#xA;&#x9;,ats_qt_peso_medio_vagoes&#xA;&#x9;,ats_nm_produto_composicao&#xA;&#x9;&#xA;&#x9;,sum(ats_qt_hp_locomotivas_rebocada) as ats_qt_hp_locomotivas_rebocada&#xA;&#x9;,sum(ats_qt_hp_locomotivas_total) as ats_qt_hp_locomotivas_total&#xA;&#xA;&#x9;,sum(ats_qt_hp_locomotivas_restrito_tracionada) as ats_qt_hp_locomotivas_restrito_tracionada&#xA;&#x9;,sum(ats_qt_hp_locomotivas_restrito_rebocada) as ats_qt_hp_locomotivas_restrito_rebocada&#xA;&#x9;,sum(ats_qt_hp_locomotivas_restrito_total) as ats_qt_hp_locomotivas_restrito_total&#xA;&#xA;&#x9;,sum(ats_qt_hp_locomotivas_disponivel_tracionada) as ats_qt_hp_locomotivas_disponivel_tracionada&#xA;&#x9;,sum(ats_qt_hp_locomotivas_disponivel_rebocada) as ats_qt_hp_locomotivas_disponivel_rebocada&#xA;&#x9;,sum(ats_hp_locomotivas_disponivel_total) as ats_hp_locomotivas_disponivel_total&#xA;&#x9;&#xA;&#x9;,sum(ats_qt_locomotivas_total) as ats_qt_locomotivas_total&#xA;&#xA;&#x9;,STRING_AGG(CASE WHEN ats_qt_locomotivas_tracionado &gt; 0 &#xA;                 THEN CAST(ats_qt_locomotivas_tracionado AS NVARCHAR(20)) + ' ' + ats_cd_serie_locomotiva &#xA;                 ELSE NULL &#xA;            END, &#xA;            '; ') WITHIN GROUP (ORDER BY ats_qt_locomotivas_tracionado)&#x9;as ModeloComposicao&#xA;&#x9;&#xA;INTO #rpAderenciaTremTipoComposicaoSerie&#xA;FROM CORP.rpAderenciaTremTipoComposicaoSerie ad&#xA;--where ats_cd_prefixo_trem = 'M380'-- and ats_id_composicao = '4669004'&#xA;GROUP BY&#xA;&#x9;ats_id_composicao&#xA;&#x9;,ats_vl_comprimento_composicao&#xA;&#x9;,ats_dt_partida_trem&#xA;&#x9;,ats_dt_chegada_trem&#xA;&#x9;,ats_dt_formacao_composicao&#xA;&#x9;,ats_ds_corredor_origem_os&#xA;&#x9;,ats_ds_corredor_origem_composicao&#xA;&#x9;,ats_ds_corredor_destino_composicao&#xA;&#x9;,ats_cd_estacao_origem_composicao&#xA;&#x9;,ats_cd_estacao_destino_composicao&#xA;&#x9;,ats_ds_tipo_composicao&#xA;&#x9;,ats_sn_tracao_isolada&#xA;&#x9;,ats_qt_tku_composicao&#xA;&#x9;,ats_qt_km_percorrido&#xA;&#x9;,ats_cd_posicao_distribuida&#xA;&#x9;,ats_qt_vagoes_vazios&#xA;&#x9;,ats_qt_vagoes_carregados&#xA;&#x9;,ats_qt_peso_medio_vagoes&#xA;&#x9;,ats_nm_produto_composicao&#xA;&#x9;,ats_cd_prefixo_trem;&#xA;&#xA;SELECT &#xA;&#x9;thr_cd_ordem_servico,&#xA;&#x9;thr_cd_ordem_servico_correlata,&#xA;&#x9;thr_ds_classe_trem,&#xA;&#x9;thr_cd_prefixo_trem,&#xA;&#x9;thr_cd_estacao_origem,&#xA;&#x9;thr_cd_estacao_destino,&#xA;&#x9;thr_cd_area_operacional,&#xA;&#x9;thr_ds_situacao_circulacao_trem,&#xA;&#x9;thr_dt_origem,&#xA;&#x9;thr_dt_destino,&#xA;&#x9;thr_no_tempo_trem_hora_parado,&#xA;&#x9;thr_no_tempo_trem_hora_marcha ,&#xA;&#x9;thr_no_tempo_total_transit_time,&#xA;&#x9;thr_no_tempo_trem_hora_parado_aci,&#xA;&#x9;thr_no_tempo_trem_hora_parado_cco,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ele,&#xA;&#x9;thr_no_tempo_trem_hora_parado_loc,&#xA;&#x9;thr_no_tempo_trem_hora_parado_obr,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ope,&#xA;&#x9;thr_no_tempo_trem_hora_parado_pot,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ptt,&#xA;&#x9;thr_no_tempo_trem_hora_parado_vag,&#xA;&#x9;thr_no_tempo_trem_hora_parado_vpe,&#xA;&#x9;thr_no_tempo_trem_hora_parado_nao_encontrado,&#xA;&#x9;thr_dt_inclusao_registro,&#xA;&#x9;thr_dt_alteracao_registro,&#xA;&#x9;thr_sk_empresa_origem_registro,&#xA;&#x9;thr_ds_empresa_origem_registro&#xA;&#x9;--Abaixo estão os dados da rpAderenciaTremTipoLocomotivas &#xA;&#x9;--,ISNULL(ADERENCIA.atl_cd_classetrem, 'NAO SE APLICA') AS atl_cd_classetrem&#xA;&#x9;,ISNULL(ADERENCIA.atl_id_composicao, -1) AS atl_id_composicao&#xA;&#x9;,ISNULL(ADERENCIA.atl_dt_formacao_composicao, '1900-01-01 00:00:00') AS atl_dt_formacao_composicao&#xA;&#x9;,ISNULL(ADERENCIA.atl_dt_encerramento_composicao, '1900-01-01 00:00:00') AS atl_dt_encerramento_composicao&#xA;&#x9;,ISNULL(ADERENCIA.atl_qt_tu_composicao, 0) AS atl_qt_tu_composicao&#xA;&#x9;,ISNULL(ADERENCIA.atl_qt_tb_composicao, 0) AS atl_qt_tb_composicao&#xA;&#x9;,ISNULL(ADERENCIA.atl_qt_paradas_trem, 0) AS atl_qt_paradas_trem&#xA;&#x9;,ISNULL(ADERENCIA.atl_qt_tkb_composicao, 0) AS atl_qt_tkb_composicao&#xA;&#x9;,ISNULL(ADERENCIA.atl_vl_consumo_composicao, 0) AS atl_vl_consumo_composicao&#xA;&#x9;,CASE &#xA;&#x9;&#x9;WHEN &#xA;&#x9;&#x9;&#x9;ADERENCIA.atl_qt_hp_locomotiva IS NULL &#xA;&#x9;&#x9;&#x9;OR ADERENCIA.atl_qt_hp_locomotiva = 0 &#xA;&#x9;&#x9;&#x9;OR ADERENCIA.atl_qt_tb_composicao IS NULL&#xA;&#x9;&#x9;&#x9;THEN 0 &#xA;&#x9;&#x9;ELSE CAST((ADERENCIA.atl_qt_tb_composicao / ADERENCIA.atl_qt_hp_locomotiva) AS NUMERIC(12,3))&#xA;&#x9;END AS atl_qt_tb_hp_locomotiva &#xA;&#x9;,ISNULL(ADERENCIA.atl_vl_percentual_reducao_tracao, 0) AS atl_vl_percentual_reducao_tracao&#xA;&#x9;,ISNULL(ADERENCIA.atl_qt_hp_locomotiva, 0) AS atl_qt_hp_locomotiva&#xA;&#x9;,ISNULL(ADERENCIA.atl_qt_tracionado_locomotiva, 0) AS atl_qt_tracionado_locomotiva&#xA;&#x9;,ISNULL(ADERENCIA.atl_qt_rebocado_locomotiva, 0) AS atl_qt_rebocado_locomotiva&#xA;&#x9;,ROW_NUMBER() OVER(PARTITION BY thr_cd_ordem_servico, thr_cd_prefixo_trem, thr_cd_estacao_origem, thr_cd_estacao_destino, thr_dt_origem, thr_dt_destino ,&#xA;&#x9;thr_cd_area_operacional ORDER BY thr_cd_ordem_servico_correlata desc) AS RN&#xA;&#x9;,thr_cd_classetrem&#xA;&#x9;--Abaixo novas colunas adicionadas na estória 261633 - Coluna de sequencia de estações e Dados da rpAderenciaTremTipoComposicaoSerie&#xA;&#x9;,ROW_NUMBER() OVER (PARTITION BY thr_cd_ordem_servico ORDER BY thr_dt_origem, thr_dt_destino) as Sequencia&#xA;&#x9;,ISNULL(ad.ats_ds_corredor_origem_os,'NÃO ENCONTRADO')&#x9;&#x9;&#x9;AS ats_ds_corredor_origem_os&#xA;&#x9;,ISNULL(ad.ats_vl_comprimento_composicao,-1)&#x9;AS ats_vl_comprimento_composicao&#xA;&#x9;,ISNULL(ad.ats_dt_partida_trem,'1900-01-01 00:00:00')&#x9;&#x9;&#x9;AS ats_dt_partida_trem&#xA;&#x9;,ISNULL(ad.ats_dt_chegada_trem,'1900-01-01 00:00:00')&#x9;&#x9;&#x9;AS ats_dt_chegada_trem&#xA;&#x9;,ISNULL(ad.ats_ds_corredor_origem_composicao,'NÃO ENCONTRADO')&#x9;AS ats_ds_corredor_origem_composicao&#xA;&#x9;,ISNULL(ad.ats_ds_corredor_destino_composicao,'NÃO ENCONTRADO')&#x9;AS ats_ds_corredor_destino_composicao&#xA;&#x9;,ISNULL(ad.ats_cd_estacao_origem_composicao,'NSA')&#x9;&#x9;&#x9;&#x9;AS ats_cd_estacao_origem_composicao&#xA;&#x9;,ISNULL(ad.ats_cd_estacao_destino_composicao,'NSA')&#x9;&#x9;&#x9;&#x9;AS ats_cd_estacao_destino_composicao&#xA;&#x9;,ISNULL(ad.ats_ds_tipo_composicao,'NÃO ENCONTRADO')&#x9;&#x9;&#x9;&#x9;AS ats_ds_tipo_composicao&#xA;&#x9;,ISNULL(ad.ats_sn_tracao_isolada,'NSA')&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ats_sn_tracao_isolada&#xA;&#x9;,ISNULL(ad.ats_qt_tku_composicao,-1)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ats_qt_tku_composicao&#xA;&#x9;,ISNULL(ad.ats_qt_km_percorrido,-1)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ats_qt_km_percorrido&#xA;&#x9;,ISNULL(ad.ats_cd_posicao_distribuida,'NSA')&#x9;&#x9;&#x9;&#x9;&#x9;AS ats_cd_posicao_distribuida&#xA;&#x9;,ISNULL(ad.ats_qt_vagoes_vazios,-1)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ats_qt_vagoes_vazios&#xA;&#x9;,ISNULL(ad.ats_qt_vagoes_carregados,-1)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ats_qt_vagoes_carregados&#xA;&#x9;,ISNULL(ad.ats_qt_peso_medio_vagoes,-1)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ats_qt_peso_medio_vagoes&#xA;&#x9;,ISNULL(ad.ats_nm_produto_composicao,'NÃO ENCONTRADO')&#x9;&#x9;&#x9;AS ats_nm_produto_composicao&#xA;&#x9;,ISNULL(ad.ats_qt_hp_locomotivas_rebocada,-1)&#x9;&#x9;&#x9;&#x9;&#x9;AS ats_qt_hp_locomotivas_rebocada&#xA;&#x9;,ISNULL(ad.ats_qt_hp_locomotivas_total,-1)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ats_qt_hp_locomotivas_total&#xA;&#x9;,ISNULL(ad.ats_qt_hp_locomotivas_restrito_tracionada,-1)&#x9;&#x9;AS ats_qt_hp_locomotivas_restrito_tracionada&#xA;&#x9;,ISNULL(ad.ats_qt_hp_locomotivas_restrito_rebocada,-1)&#x9;&#x9;&#x9;AS ats_qt_hp_locomotivas_restrito_rebocada&#xA;&#x9;,ISNULL(ad.ats_qt_hp_locomotivas_restrito_total,-1)&#x9;&#x9;&#x9;&#x9;AS ats_qt_hp_locomotivas_restrito_total&#xA;&#x9;,ISNULL(ad.ats_qt_hp_locomotivas_disponivel_tracionada,-1)&#x9;&#x9;AS ats_qt_hp_locomotivas_disponivel_tracionada&#xA;&#x9;,ISNULL(ad.ats_qt_hp_locomotivas_disponivel_rebocada,-1)&#x9;&#x9;AS ats_qt_hp_locomotivas_disponivel_rebocada&#xA;&#x9;,ISNULL(ad.ats_hp_locomotivas_disponivel_total,-1)&#x9;&#x9;&#x9;&#x9;AS ats_hp_locomotivas_disponivel_total&#xA;&#x9;,ISNULL(ad.ats_qt_locomotivas_total,-1)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ats_qt_locomotivas_total&#xA;&#x9;,ISNULL(ad.ModeloComposicao,'NÃO ENCONTRADO')&#x9;&#x9;&#x9;&#x9;&#x9;AS ModeloComposicao&#xA;&#x9;,thr_ft_velocidade_maxima_alcancavel_classetrem --US 264063&#xA;INTO #TT_RETIRA_DUPLICADOS&#xA;FROM #TT_DTMEDIA AS TT_DTMEDIA&#xA;LEFT JOIN #ADERENCIA AS ADERENCIA&#xA;&#x9;ON TT_DTMEDIA.thr_cd_ordem_servico = ADERENCIA.atl_no_ordem_servico_trem&#xA;&#x9;&#x9;AND TT_DTMEDIA.thr_dt_media BETWEEN ADERENCIA.atl_dt_formacao_composicao AND ADERENCIA.atl_dt_encerramento_composicao&#xA;LEFT JOIN #rpAderenciaTremTipoComposicaoSerie  ad on ad.ats_id_composicao = ADERENCIA.atl_id_composicao&#xA;&#xA;&#xA;SELECT *&#xA;&#x9;,thr_cd_hash_unique_keys = CONVERT(CHAR(32),HASHBYTES('MD5',concat_ws('_',thr_cd_ordem_servico,thr_cd_ordem_servico_correlata,thr_cd_area_operacional,thr_sk_empresa_origem_registro)),2)&#xA;&#x9;,thr_cd_hash_chave_update = CONVERT(CHAR(32),HASHBYTES('SHA2_512',CONCAT_WS('_',&#xA;&#x9;&#x9;thr_cd_ordem_servico,&#xA;&#x9;&#x9;thr_cd_ordem_servico_correlata,&#xA;&#x9;&#x9;thr_ds_classe_trem,&#xA;&#x9;&#x9;thr_cd_prefixo_trem,&#xA;&#x9;&#x9;thr_cd_estacao_origem,&#xA;&#x9;&#x9;thr_cd_estacao_destino,&#xA;&#x9;&#x9;thr_cd_area_operacional,&#xA;&#x9;&#x9;thr_ds_situacao_circulacao_trem,&#xA;&#x9;&#x9;thr_dt_origem,&#xA;&#x9;&#x9;thr_dt_destino,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_marcha ,&#xA;&#x9;&#x9;thr_no_tempo_total_transit_time,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado_aci,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado_cco,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado_ele,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado_loc,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado_obr,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado_ope,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado_pot,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado_ptt,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado_vag,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado_vpe,&#xA;&#x9;&#x9;thr_no_tempo_trem_hora_parado_nao_encontrado,&#xA;&#x9;&#x9;thr_sk_empresa_origem_registro,&#xA;&#x9;&#x9;thr_ds_empresa_origem_registro&#xA;&#x9;--Abaixo estão os dados da rpAderenciaTremTipoLocomotivas &#xA;&#x9;,thr_cd_classetrem&#xA;&#x9;,atl_id_composicao&#xA;&#x9;,atl_dt_formacao_composicao&#xA;&#x9;,atl_dt_encerramento_composicao&#xA;&#x9;,atl_qt_tu_composicao&#xA;&#x9;,atl_qt_tb_composicao&#xA;&#x9;,atl_qt_paradas_trem&#xA;&#x9;,atl_qt_tkb_composicao&#xA;&#x9;,atl_vl_consumo_composicao&#xA;&#x9;,atl_qt_tb_hp_locomotiva &#xA;&#x9;,atl_vl_percentual_reducao_tracao&#xA;&#x9;,atl_qt_hp_locomotiva&#xA;&#x9;,atl_qt_tracionado_locomotiva&#xA;&#x9;,atl_qt_rebocado_locomotiva&#x9;&#xA;&#x9;--Abaixo novas colunas adicionadas na estória 261633 - Coluna de sequencia de estações e Dados da rpAderenciaTremTipoComposicaoSerie&#xA;&#x9;,Sequencia&#xA;&#x9;,ats_ds_corredor_origem_os&#xA;&#x9;,ats_vl_comprimento_composicao&#xA;&#x9;,ats_dt_partida_trem&#xA;&#x9;,ats_dt_chegada_trem&#xA;&#x9;,ats_ds_corredor_origem_composicao&#xA;&#x9;,ats_ds_corredor_destino_composicao&#xA;&#x9;,ats_cd_estacao_origem_composicao&#xA;&#x9;,ats_cd_estacao_destino_composicao&#xA;&#x9;,ats_ds_tipo_composicao&#xA;&#x9;,ats_sn_tracao_isolada&#xA;&#x9;,ats_qt_tku_composicao&#xA;&#x9;,ats_qt_km_percorrido&#xA;&#x9;,ats_cd_posicao_distribuida&#xA;&#x9;,ats_qt_vagoes_vazios&#xA;&#x9;,ats_qt_vagoes_carregados&#xA;&#x9;,ats_qt_peso_medio_vagoes&#xA;&#x9;,ats_nm_produto_composicao&#xA;&#x9;,ats_qt_hp_locomotivas_rebocada&#xA;&#x9;,ats_qt_hp_locomotivas_total&#xA;&#x9;,ats_qt_hp_locomotivas_restrito_tracionada&#xA;&#x9;,ats_qt_hp_locomotivas_restrito_rebocada&#xA;&#x9;,ats_qt_hp_locomotivas_restrito_total&#xA;&#x9;,ats_qt_hp_locomotivas_disponivel_tracionada&#xA;&#x9;,ats_qt_hp_locomotivas_disponivel_rebocada&#xA;&#x9;,ats_hp_locomotivas_disponivel_total&#xA;&#x9;,ats_qt_locomotivas_total&#xA;&#x9;,ModeloComposicao&#xA;&#x9;,thr_ft_velocidade_maxima_alcancavel_classetrem)),2)&#xA;INTO #TT_COM_HASH&#xA;FROM #TT_RETIRA_DUPLICADOS&#xA;WHERE RN=1&#xA;/* Filtro adicionado para coletar apenas dados do ano anterior e do ano atual */&#xA;AND &#xA;(&#xA;&#x9;CASE WHEN thr_dt_origem='1900-01-01 00:00:00.000' THEN thr_dt_destino &#xA;&#x9;ELSE thr_dt_origem END&#xA;) &gt;= DATEFROMPARTS(YEAR(GETDATE())-1,1,1)&#xA;&#xA;&#xA;IF @FULL = 0&#xA;BEGIN&#xA;&#xA;SET @dataInicio = (SELECT MIN(ttt_dt_origem) FROM corp.rpTemposTransitTime)&#xA;SET @dataFim = @dataProcessamento; --dataBancoSSIS&#xA;&#xA;TRUNCATE TABLE corp_stg.rpTemposTransitTimeResponsabilidade&#xA;&#xA;END&#xA;&#xA;INSERT INTO corp_stg.rpTemposTransitTimeResponsabilidade&#xA;(&#xA;&#x9;thr_cd_ordem_servico,&#xA;&#x9;thr_cd_ordem_servico_correlata,&#xA;&#x9;thr_ds_classe_trem,&#xA;&#x9;thr_cd_prefixo_trem,&#xA;&#x9;thr_cd_estacao_origem,&#xA;&#x9;thr_cd_estacao_destino,&#xA;&#x9;thr_cd_area_operacional,&#xA;&#x9;thr_ds_situacao_circulacao_trem,&#xA;&#x9;thr_dt_origem,&#xA;&#x9;thr_dt_destino,&#xA;&#x9;thr_no_tempo_trem_hora_parado,&#xA;&#x9;thr_no_tempo_trem_hora_marcha ,&#xA;&#x9;thr_no_tempo_total_transit_time,&#xA;&#x9;thr_no_tempo_trem_hora_parado_aci,&#xA;&#x9;thr_no_tempo_trem_hora_parado_cco,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ele,&#xA;&#x9;thr_no_tempo_trem_hora_parado_loc,&#xA;&#x9;thr_no_tempo_trem_hora_parado_obr,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ope,&#xA;&#x9;thr_no_tempo_trem_hora_parado_pot,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ptt,&#xA;&#x9;thr_no_tempo_trem_hora_parado_vag,&#xA;&#x9;thr_no_tempo_trem_hora_parado_vpe,&#xA;&#x9;thr_no_tempo_trem_hora_parado_nao_encontrado,&#xA;&#x9;thr_dt_inclusao_registro, &#xA;&#x9;thr_dt_alteracao_registro&#xA;&#x9;,thr_sk_empresa_origem_registro&#xA;&#x9;,thr_ds_empresa_origem_registro&#xA;&#x9;--Abaixo estão os dados da rpAderenciaTremTipoLocomotivas &#xA;&#x9;,thr_cd_classetrem&#xA;&#x9;,thr_id_composicao&#x9;  &#xA;&#x9;,thr_dt_formacao_composicao&#xA;&#x9;,thr_dt_encerramento_composicao&#xA;&#x9;,thr_qt_na_tu_composicao&#xA;&#x9;,thr_qt_na_tb_composicao&#xA;&#x9;,thr_qt_na_paradas_trem&#x9;  &#xA;&#x9;,thr_qt_na_tkb_composicao&#x9;  &#xA;&#x9;,thr_vl_consumo_composicao&#xA;&#x9;,thr_qt_tb_hp_locomotiva&#xA;&#x9;,thr_vl_percentual_reducao_tracao&#xA;&#x9;,thr_qt_hp_locomotiva&#xA;&#x9;,thr_qt_tracionado_locomotiva&#xA;&#x9;,thr_qt_rebocado_locomotiva&#xA;&#x9;--&#xA;&#x9;,thr_no_sequencia_estacao_ordem_servico&#xA;&#x9;,thr_ds_corredor_origem_ordem_servico&#xA;&#x9;,thr_vl_comprimento_composicao&#xA;&#x9;,thr_dt_partida_trem_composicao&#xA;&#x9;,thr_dt_chegada_trem_composicao&#xA;&#x9;,thr_ds_corredor_origem_composicao&#xA;&#x9;,thr_ds_corredor_destino_composicao&#xA;&#x9;,thr_cd_estacao_origem_composicao&#xA;&#x9;,thr_cd_estacao_destino_composicao&#xA;&#x9;,thr_ds_tipo_composicao&#xA;&#x9;,thr_sn_tracao_isolada_composicao&#xA;&#x9;,thr_qt_tku_composicao&#xA;&#x9;,thr_qt_km_percorrido_composicao&#xA;&#x9;,thr_cd_posicao_distribuida_composicao&#xA;&#x9;,thr_qt_vagoes_vazios_composicao&#xA;&#x9;,thr_qt_vagoes_carregados_composicao&#xA;&#x9;,thr_qt_peso_medio_vagoes_composicao&#xA;&#x9;,thr_nm_produto_composicao&#xA;&#x9;,thr_qt_hp_locomotivas_rebocadas_composicao&#xA;&#x9;,thr_qt_hp_total_locomotivas_composicao&#xA;&#x9;,thr_qt_hp_restrito_locomotivas_tracionadas_composicao&#xA;&#x9;,thr_qt_hp_restrito_locomotivas_rebocadas_composicao&#xA;&#x9;,thr_qt_hp_restrito_total_locomotivas_composicao&#xA;&#x9;,thr_qt_hp_disponivel_locomotivas_tracionadas_composicao&#xA;&#x9;,thr_qt_hp_disponivel_locomotivas_rebocadas_composicao&#xA;&#x9;,thr_qt_hp_disponivel_total_locomotivas_composicao&#xA;&#x9;,thr_qt_total_locomotivas_composicao&#xA;&#x9;,thr_ds_modelos_serie_locomotivas_composicao&#xA;&#x9;,thr_ft_velocidade_maxima_alcancavel_classetrem --US 264063&#xA;&#x9;-- US 271434&#xA;&#x9;,thr_cd_hash_unique_keys&#xA;&#x9;,thr_cd_hash_chave_update&#xA;&#xA;)&#xA;&#xA;SELECT &#xA;&#x9;thr_cd_ordem_servico,&#xA;&#x9;thr_cd_ordem_servico_correlata,&#xA;&#x9;thr_ds_classe_trem,&#xA;&#x9;thr_cd_prefixo_trem,&#xA;&#x9;thr_cd_estacao_origem,&#xA;&#x9;thr_cd_estacao_destino,&#xA;&#x9;thr_cd_area_operacional,&#xA;&#x9;thr_ds_situacao_circulacao_trem,&#xA;&#x9;thr_dt_origem,&#xA;&#x9;thr_dt_destino,&#xA;&#x9;thr_no_tempo_trem_hora_parado,&#xA;&#x9;thr_no_tempo_trem_hora_marcha ,&#xA;&#x9;thr_no_tempo_total_transit_time,&#xA;&#x9;thr_no_tempo_trem_hora_parado_aci,&#xA;&#x9;thr_no_tempo_trem_hora_parado_cco,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ele,&#xA;&#x9;thr_no_tempo_trem_hora_parado_loc,&#xA;&#x9;thr_no_tempo_trem_hora_parado_obr,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ope,&#xA;&#x9;thr_no_tempo_trem_hora_parado_pot,&#xA;&#x9;thr_no_tempo_trem_hora_parado_ptt,&#xA;&#x9;thr_no_tempo_trem_hora_parado_vag,&#xA;&#x9;thr_no_tempo_trem_hora_parado_vpe,&#xA;&#x9;thr_no_tempo_trem_hora_parado_nao_encontrado,&#xA;&#x9;thr_dt_inclusao_registro,&#xA;&#x9;thr_dt_alteracao_registro,&#xA;&#x9;thr_sk_empresa_origem_registro,&#xA;&#x9;thr_ds_empresa_origem_registro&#xA;&#x9;--Abaixo estão os dados da rpAderenciaTremTipoLocomotivas &#xA;&#x9;,thr_cd_classetrem&#xA;&#x9;,atl_id_composicao&#xA;&#x9;,atl_dt_formacao_composicao&#xA;&#x9;,atl_dt_encerramento_composicao&#xA;&#x9;,atl_qt_tu_composicao&#xA;&#x9;,atl_qt_tb_composicao&#xA;&#x9;,atl_qt_paradas_trem&#xA;&#x9;,atl_qt_tkb_composicao&#xA;&#x9;,atl_vl_consumo_composicao&#xA;&#x9;,atl_qt_tb_hp_locomotiva &#xA;&#x9;,atl_vl_percentual_reducao_tracao&#xA;&#x9;,atl_qt_hp_locomotiva&#xA;&#x9;,atl_qt_tracionado_locomotiva&#xA;&#x9;,atl_qt_rebocado_locomotiva&#x9;&#xA;&#x9;--Abaixo novas colunas adicionadas na estória 261633 - Coluna de sequencia de estações e Dados da rpAderenciaTremTipoComposicaoSerie&#xA;&#x9;,Sequencia&#xA;&#x9;,ats_ds_corredor_origem_os&#xA;&#x9;,ats_vl_comprimento_composicao&#xA;&#x9;,ats_dt_partida_trem&#xA;&#x9;,ats_dt_chegada_trem&#xA;&#x9;,ats_ds_corredor_origem_composicao&#xA;&#x9;,ats_ds_corredor_destino_composicao&#xA;&#x9;,ats_cd_estacao_origem_composicao&#xA;&#x9;,ats_cd_estacao_destino_composicao&#xA;&#x9;,ats_ds_tipo_composicao&#xA;&#x9;,ats_sn_tracao_isolada&#xA;&#x9;,ats_qt_tku_composicao&#xA;&#x9;,ats_qt_km_percorrido&#xA;&#x9;,ats_cd_posicao_distribuida&#xA;&#x9;,ats_qt_vagoes_vazios&#xA;&#x9;,ats_qt_vagoes_carregados&#xA;&#x9;,ats_qt_peso_medio_vagoes&#xA;&#x9;,ats_nm_produto_composicao&#xA;&#x9;,ats_qt_hp_locomotivas_rebocada&#xA;&#x9;,ats_qt_hp_locomotivas_total&#xA;&#x9;,ats_qt_hp_locomotivas_restrito_tracionada&#xA;&#x9;,ats_qt_hp_locomotivas_restrito_rebocada&#xA;&#x9;,ats_qt_hp_locomotivas_restrito_total&#xA;&#x9;,ats_qt_hp_locomotivas_disponivel_tracionada&#xA;&#x9;,ats_qt_hp_locomotivas_disponivel_rebocada&#xA;&#x9;,ats_hp_locomotivas_disponivel_total&#xA;&#x9;,ats_qt_locomotivas_total&#xA;&#x9;,ModeloComposicao&#xA;&#x9;--&#xA;&#x9;,thr_ft_velocidade_maxima_alcancavel_classetrem --US 264063&#xA;&#x9;,thr_cd_hash_unique_keys&#xA;&#x9;,thr_cd_hash_chave_update&#xA;&#xA;FROM #TT_COM_HASH&#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="User::Data_inicio_execucao"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="7"
