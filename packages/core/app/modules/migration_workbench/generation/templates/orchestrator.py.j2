# MAGIC %md
{%- if include_docstring_header %}
# MAGIC # {{ package_name }} - Orchestrator
# MAGIC
# MAGIC **Source**: SSIS package `{{ package_name }}`
# MAGIC **Strategy**: Modular (PySpark orchestrator + SQL modules)
# MAGIC **Generated**: {{ generated_at }}
# MAGIC
# MAGIC ## Modules
{%- for m in sql_modules %}
# MAGIC - `{{ m.name }}` — {{ m.purpose }}
{%- endfor %}
{%- endif %}

# COMMAND ----------

# MAGIC %md
# MAGIC ## Parameters

# COMMAND ----------

dbutils.widgets.text("run_date", "", "Run Date (YYYY-MM-DD)")
dbutils.widgets.text("catalog", "{{ target_catalog }}", "Unity Catalog")
dbutils.widgets.text("schema", "{{ target_schema }}", "Target Schema")

run_date = dbutils.widgets.get("run_date")
catalog = dbutils.widgets.get("catalog")
schema = dbutils.widgets.get("schema")

print(f"Orchestrating migration: catalog={catalog}, schema={schema}, run_date={run_date}")

# COMMAND ----------

# MAGIC %md
# MAGIC ## Module Execution
# MAGIC
# MAGIC Each SQL module is invoked via `dbutils.notebook.run`. A non-zero exit
# MAGIC value from any module aborts the chain.

# COMMAND ----------

from datetime import datetime

TIMEOUT_SECONDS = 3600

modules = [
{%- for m in sql_modules %}
    {
        "name": "{{ m.name }}",
        "path": "./{{ m.name }}",
        "purpose": "{{ m.purpose }}",
    },
{%- endfor %}
]

shared_params = {
    "catalog": catalog,
    "schema": schema,
    "run_date": run_date,
}

results = []
for module in modules:
    started = datetime.utcnow()
    print(f"[{started.isoformat()}] -> {module['name']}: {module['purpose']}")
    try:
        exit_value = dbutils.notebook.run(
            module["path"],
            TIMEOUT_SECONDS,
            shared_params,
        )
        results.append({
            "module": module["name"],
            "status": "success",
            "exit": exit_value,
            "duration_s": (datetime.utcnow() - started).total_seconds(),
        })
        print(f"   OK ({(datetime.utcnow() - started).total_seconds():.1f}s) -> {exit_value}")
    except Exception as exc:
        results.append({
            "module": module["name"],
            "status": "failed",
            "error": str(exc),
            "duration_s": (datetime.utcnow() - started).total_seconds(),
        })
        print(f"   FAILED: {exc}")
        raise

# COMMAND ----------

# MAGIC %md
# MAGIC ## Summary

# COMMAND ----------

import json
print(json.dumps(results, indent=2, default=str))

dbutils.notebook.exit(json.dumps({"status": "success", "modules": len(results)}))
