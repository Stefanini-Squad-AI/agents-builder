# Agents Workshop — environment template
# Copy to .env and fill values. .env is gitignored.

# -------------------------------------------------------------------
# Postgres
# -------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://workshop:workshop@127.0.0.1:5433/workshop

# -------------------------------------------------------------------
# Redis (Dramatiq broker + light cache)
# -------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0

# -------------------------------------------------------------------
# LLM defaults
#   Anthropic is the only default. OpenAI + Ollama are opt-in:
#   set their respective vars (key / base URL) to enable them.
# -------------------------------------------------------------------
WORKSHOP_DEFAULT_PROVIDER=bedrock
WORKSHOP_DEFAULT_MODEL=claude-sonnet-4
WORKSHOP_TEMPERATURE=0.20

# -------------------------------------------------------------------
# Provider credentials (presence enables the provider)
# -------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# -------------------------------------------------------------------
# Storage
# -------------------------------------------------------------------
WORKSHOP_DATA_DIR=./data

# -------------------------------------------------------------------
# Web (Next.js)
# -------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# -------------------------------------------------------------------
# AWS Bedrock (set WORKSHOP_DEFAULT_PROVIDER=bedrock to use)
# -------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-2

# -------------------------------------------------------------------
# Encryption (for MCP secrets at rest)
# -------------------------------------------------------------------
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, MCP secrets are stored as plain JSON (not recommended for production).
WORKSHOP_ENCRYPTION_KEY=